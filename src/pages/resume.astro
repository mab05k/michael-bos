---
import InnerLayout from '../layouts/InnerLayout.astro';
---
<InnerLayout
  title="Resume"
  activePage="resume"
  description="Resume of Michael A. Bos — Senior Engineering Manager with experience leading distributed engineering teams, building cloud-native systems, and scaling developer infrastructure."
>
  <style is:global>
    .page-intro {
      max-width: 1280px;
      margin: 32px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: end;
    }
    .page-intro .eyebrow { margin-bottom: 12px; }
    .page-intro h1 {
      font-family: var(--font-sans);
      font-size: 56px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.025em;
      line-height: 1;
      color: var(--ink-900);
    }
    .page-intro .dek {
      max-width: 90ch;
      margin-top: 18px;
      color: var(--ink-700);
      font-size: var(--fs-16);
      line-height: 1.55;
      text-wrap: pretty;
    }
    .page-intro .actions { display: flex; gap: 12px; align-items: center; }
    .page-intro .actions button,
    .page-intro .actions a {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 16px;
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      text-transform: uppercase;
      letter-spacing: var(--tr-caps);
      border-radius: var(--r-sm);
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      color: var(--ink-800);
      cursor: pointer;
      transition: background var(--dur-fast) var(--ease-out);
    }
    .page-intro .actions button:hover,
    .page-intro .actions a:hover { background: var(--card-bg-deep); }
    .page-intro .actions .primary {
      background: var(--moss-500);
      color: var(--ink-50);
      border-color: var(--moss-700);
    }
    .page-intro .actions .primary:hover { background: var(--moss-600); }

    .identity {
      max-width: 1280px;
      margin: 40px auto 0;
      padding: 0 24px;
    }
    .identity-inner {
      display: grid;
      grid-template-columns: auto 1fr auto;
      gap: 20px 28px;
      align-items: center;
      padding: 26px 0;
      border-top: 1px solid var(--rule-strong);
      border-bottom: 1px solid var(--rule-strong);
    }
    .identity-portrait {
      width: 92px;
      height: 92px;
      border-radius: 50%;
      object-fit: cover;
      object-position: center top;
      flex-shrink: 0;
      border: 1px solid var(--card-border);
    }
    .identity-name {
      font-family: var(--font-sans);
      font-weight: var(--fw-semibold);
      font-size: 32px;
      letter-spacing: -0.02em;
      color: var(--ink-900);
      line-height: 1.05;
    }
    .identity-title {
      margin-top: 6px;
      font-size: var(--fs-16);
      color: var(--ink-700);
    }
    .identity-meta {
      margin-top: 12px;
      display: flex;
      flex-wrap: wrap;
      gap: 6px 14px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
    }
    .identity-meta .sep { color: var(--clay-600); }
    .identity-contact {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 9px;
      font-family: var(--font-mono);
      font-size: var(--fs-12);
    }
    .identity-contact a {
      color: var(--ink-800);
      text-decoration: none;
      border-bottom: 1px solid var(--ink-300);
      padding-bottom: 1px;
    }
    .identity-contact a:hover { color: var(--moss-700); border-bottom-color: var(--moss-500); }

    .summary {
      max-width: 1280px;
      margin: 40px auto 0;
      padding: 0 24px;
    }
    .summary .head {
      display: flex; align-items: baseline; gap: 16px;
      padding-bottom: 12px;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .summary .head h2 {
      font-family: var(--font-sans);
      font-size: 22px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.015em;
      color: var(--ink-900);
    }
    .summary .head .meta {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      text-transform: uppercase;
      letter-spacing: var(--tr-caps);
      color: var(--ink-500);
    }
    .summary p {
      font-size: 17px;
      line-height: 1.6;
      color: var(--ink-700);
      margin: 0;
      text-wrap: pretty;
    }
    .summary p strong { color: var(--ink-900); font-weight: var(--fw-semibold); }

    .record {
      max-width: 1280px;
      margin: 56px auto 0;
      padding: 0 24px;
    }
    .record-head {
      display: flex; align-items: baseline; gap: 16px;
      padding-bottom: 12px;
      margin-bottom: 24px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .record-head h2 {
      font-family: var(--font-sans);
      font-size: 26px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.02em;
      color: var(--ink-900);
    }
    .record-head .meta {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      text-transform: uppercase;
      letter-spacing: var(--tr-caps);
      color: var(--ink-500);
    }

    .tour { margin-bottom: 8px; }
    .tour-band {
      display: grid;
      grid-template-columns: 200px 1fr auto;
      column-gap: 32px;
      align-items: baseline;
      padding: 14px 0;
      border-top: 1px solid var(--rule-strong);
    }
    .tour-band .idx {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      font-weight: var(--fw-semibold);
      color: var(--ink-500);
      letter-spacing: var(--tr-caps);
    }
    .tour-band .org { display: flex; align-items: baseline; gap: 14px; flex-wrap: wrap; }
    .tour-band .org .name {
      font-family: var(--font-sans);
      font-size: 22px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.015em;
      color: var(--ink-900);
    }
    .tour-band .org .place {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
    }
    .tour-band .dates {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-700);
      white-space: nowrap;
    }

    .role {
      display: grid;
      grid-template-columns: 200px 1fr;
      column-gap: 32px;
      padding: 18px 0 24px;
      border-top: 1px dashed var(--border-subtle);
    }
    .role .role-meta {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: 0.02em;
      color: var(--ink-700);
      line-height: 1.5;
    }
    .role .role-meta .dates {
      display: block;
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      font-weight: var(--fw-semibold);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--clay-600);
      margin-bottom: 8px;
    }
    .role .role-meta .fact {
      display: block;
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
      margin-bottom: 5px;
    }
    .role .role-meta .pill-row { margin-top: 10px; display: flex; flex-direction: column; gap: 6px; align-items: flex-start; }

    .role .role-body { padding-top: 0; }
    .role .role-body .title {
      font-family: var(--font-sans);
      font-weight: var(--fw-semibold);
      font-size: 18px;
      color: var(--ink-900);
      letter-spacing: -0.01em;
      margin-bottom: 10px;
    }
    .role .role-body .desc {
      color: var(--ink-700);
      font-size: var(--fs-14);
      line-height: 1.55;
      margin: 0 0 14px;
      max-width: 75ch;
      text-wrap: pretty;
    }
    .role .role-body .desc strong { color: var(--ink-900); font-weight: var(--fw-semibold); }

    .role .role-body ul.actions-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .role .role-body ul.actions-list li {
      display: grid;
      grid-template-columns: 28px 1fr;
      column-gap: 12px;
      align-items: baseline;
      font-size: var(--fs-14);
      line-height: 1.55;
      color: var(--ink-700);
      max-width: 80ch;
      text-wrap: pretty;
    }
    .role .role-body ul.actions-list li .num {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      color: var(--ink-400);
      padding-top: 2px;
    }
    .role .role-body ul.actions-list li strong { color: var(--ink-900); font-weight: var(--fw-semibold); }
    .role .role-body ul.actions-list li .clay { color: var(--clay-600); font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

    .lower {
      max-width: 1280px;
      margin: 64px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
    }
    .lower section .head {
      display: flex; align-items: baseline; gap: 16px;
      padding-bottom: 12px;
      margin-bottom: 20px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .lower section .head h2 {
      font-family: var(--font-sans);
      font-size: 22px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.015em;
      color: var(--ink-900);
    }
    .lower section .head .meta {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      text-transform: uppercase;
      letter-spacing: var(--tr-caps);
      color: var(--ink-500);
    }

    .skills-group { margin-bottom: 22px; }
    .skills-group .gk {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
      margin-bottom: 8px;
    }
    .skills-group .tags { display: flex; flex-wrap: wrap; gap: 6px; }
    .skill-tag {
      display: inline-flex; align-items: center; gap: 6px;
      padding: 4px 10px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--r-sm);
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      color: var(--ink-800);
      letter-spacing: 0.01em;
    }
    .skill-tag img { width: 14px; height: 14px; flex-shrink: 0; }
    .skill-tag.primary { background: var(--bg-bone); border-color: var(--hairline-strong); color: var(--canyon-shadow); }
    .skill-tag.clay    { background: var(--clay-50); border-color: var(--clay-100); color: var(--clay-700); }

    .row-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 16px;
      padding: 14px 0;
      border-top: 1px dashed var(--border-subtle);
    }
    .row-item:first-of-type { border-top: 1px solid var(--rule-strong); padding-top: 14px; }
    .row-item .a { display: flex; flex-direction: column; gap: 4px; }
    .row-item .a .title {
      font-family: var(--font-sans);
      font-size: var(--fs-16);
      color: var(--ink-900);
      font-weight: var(--fw-medium);
    }
    .row-item .a .sub {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
    }
    .row-item .b {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-700);
      text-align: right;
      white-space: nowrap;
      padding-top: 4px;
    }
    .row-item .b .accent { color: var(--clay-600); }

    .notes {
      max-width: 1280px;
      margin: 64px auto 0;
      padding: 0 24px;
      color: var(--ink-500);
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
    }

    @media print {
      body { background: white; background-image: none; }
      .site-header, .classmark, .site-footer, .page-intro .actions, .notes { display: none !important; }
      .identity-inner, .role, .tour-band { box-shadow: none !important; page-break-inside: avoid; }
      .record, .lower, .summary { page-break-inside: auto; }
      .page-intro h1 { font-size: 36px; }
    }

    @media (max-width: 900px) {
      .identity-inner { grid-template-columns: auto 1fr; }
      .identity-portrait { width: 68px; height: 68px; }
      .identity-name { font-size: 26px; }
      .identity-contact {
        grid-column: 1 / -1;
        flex-direction: row;
        flex-wrap: wrap;
        align-items: baseline;
        gap: 8px 20px;
      }
      .page-intro { grid-template-columns: 1fr; }
      .page-intro h1 { font-size: 40px; }
      .lower { grid-template-columns: 1fr; gap: 40px; }
      .tour-band { grid-template-columns: 1fr; gap: 6px; }
      .role { grid-template-columns: 1fr; gap: 12px; }
      .role .role-meta { display: flex; flex-wrap: wrap; align-items: center; gap: 8px 14px; }
      .role .role-meta .dates,
      .role .role-meta .fact { margin-bottom: 0; }
      .role .role-meta .pill-row { margin-top: 0; flex-direction: row; }
    }
  </style>

  <!-- Intro -->
  <header class="page-intro">
    <div>
      <div class="eyebrow">Resume</div>
      <h1>The full record.</h1>
      <p class="dek">
        Engineering leader with <strong>10+ years</strong> building production
        platforms and infrastructure, and <strong>4+ years</strong> running
        high-performing teams. Prior <strong>six years</strong> in U.S. Naval
        Special Warfare intelligence. Current focus: agentic platforms, MCP
        tooling, and the reliability work production AI systems require.
      </p>
    </div>
    <div class="actions">
      <button class="primary" onclick="window.print()">Print / Save PDF</button>
      <!--<a href="mailto:mab05k@gmail.com">Email</a>-->
    </div>
  </header>

  <!-- Identity band -->
  <section class="identity">
    <div class="identity-inner">
      <img src="/michael-bos-portrait.JPEG" alt="Michael A. Bos" class="identity-portrait" />
      <div class="identity-main">
        <div class="identity-name">Michael A. Bos</div>
        <div class="identity-title">Senior Software Engineering Manager · Guidepoint Global</div>
        <div class="identity-meta">
          <span>Las Vegas, NV · Remote</span>
          <span class="sep">/</span>
          <span>Distributed teams · US &amp; India</span>
        </div>
      </div>
      <div class="identity-contact">
        <a href="mailto:mab05k@gmail.com">mab05k@gmail.com</a>
        <a href="tel:+13053048599">(305) 304-8599</a>
        <a href="https://www.linkedin.com/in/michael-a-bos/" target="_blank" rel="noopener">linkedin/michael-a-bos</a>
        <a href="https://github.com/mab05k" target="_blank" rel="noopener">github/mab05k</a>
      </div>
    </div>
  </section>

  <!-- Summary -->
  <section class="summary">
    <div class="record-head">
      <h2>Summary</h2>
      <!--<span class="meta">01 / 06</span>-->
    </div>
    <p>
      Track record of owning reliability-critical platforms at scale, including a
      <strong>company-wide cloud-native migration</strong> across 10+ teams and 20+ services,
      and building <strong>observability and incident response programs</strong> from the
      ground up. Experienced in Kubernetes, CI/CD, distributed systems, and the
      cross-functional collaboration required to turn internal developer
      infrastructure into a force multiplier for an engineering organization.
      Currently leading architecture and delivery for an enterprise
      <strong>agentic platform</strong> &mdash; MCP tooling, integration with the core CRM,
      and the auth and reliability patterns production AI needs.
    </p>
  </section>

  <!-- Professional experience -->
  <section class="record" aria-label="Experience">
    <div class="record-head">
      <h2>Experience</h2>
      <span class="meta">2010 — present</span>
    </div>

    <!-- TOUR 3 — GUIDEPOINT -->
    <div class="tour">
      <div class="tour-band" style="border-top: none">
        <div class="idx"></div>
        <div class="org">
          <span class="name">Guidepoint Global</span>
          <span class="place">Las Vegas, NV · Remote</span>
        </div>
        <div class="dates">Apr 2023 — Present</div>
      </div>

      <article class="role">
        <div class="role-meta">
          <span class="dates">Jan 2026 — Present</span>
          <span class="fact">Agentic platform · MCP</span>
          <span class="fact">Architecture &amp; delivery</span>
          <div class="pill-row">
            <span class="pill active"><span class="dot"></span>Current role</span>
          </div>
        </div>
        <div class="role-body">
          <div class="title">Senior Software Engineering Manager</div>
          <p class="desc">
            Leading architecture and engineering delivery for Guidepoint&rsquo;s
            next-generation agentic platform as part of the company&rsquo;s AI
            transformation initiatives.
          </p>
          <ul class="actions-list">
            <li><span class="num">01</span><span>Defined the <strong>integration architecture</strong> between Guidepoint&rsquo;s agentic platform and core CRM.</span></li>
            <li><span class="num">02</span><span>Designing <strong>MCP-based tooling</strong> as a model-agnostic interface layer serving both internal and third-party LLM consumers.</span></li>
            <li><span class="num">03</span><span>Leading a team building production MCP tools that abstract CRM operations for agent-driven workflows.</span></li>
            <li><span class="num">04</span><span>Scoping tool boundaries, defining input/output contracts, and establishing <strong>reliability patterns for non-deterministic callers</strong>.</span></li>
            <li><span class="num">05</span><span>Partnering on auth strategies for agentic systems &mdash; <strong>OAuth2-based delegation</strong> and scoped service credentials for tool-level access control.</span></li>
            <li><span class="num">06</span><span>Collaborating cross-functionally with product and leadership to sequence AI-driven initiatives against business constraints and operational readiness.</span></li>
          </ul>
        </div>
      </article>

      <article class="role">
        <div class="role-meta">
          <span class="dates">Jan 2025 — Dec 2025</span>
          <span class="fact">11 direct reports</span>
          <span class="fact">2 teams · US &amp; India</span>
        </div>
        <div class="role-body">
          <div class="title">Software Engineering Manager</div>
          <p class="desc">
            Led two engineering teams (<strong>11 direct reports</strong>) delivering
            AI-powered features and platform modernization initiatives as part of a
            broader transformation effort.
          </p>
          <ul class="actions-list">
            <li><span class="num">01</span><span>Delivered <strong>LLM-powered features</strong> to automate Request intake workflows; reduced <span class="clay">time-to-market by 67%</span> while addressing prompt reliability and output consistency.</span></li>
            <li><span class="num">02</span><span>Redesigned the employee-facing Request interface, streamlining Advisor workflows and contributing to a <span class="clay">30–40% increase in revenue per Request</span>.</span></li>
            <li><span class="num">03</span><span><strong>Established engineering on-call from scratch</strong> &mdash; ownership models, alerting thresholds, escalation paths, and postmortem practices via Datadog and Squadcast. Reduced mean time to response across distributed systems at scale.</span></li>
            <li><span class="num">04</span><span>Hired and developed a globally distributed team across the U.S. and India &mdash; <span class="clay">3 strategic hires, 2 internal promotions</span>, performance management with full retention.</span></li>
            <li><span class="num">05</span><span>Mentored engineers on designing systems that integrate external services and AI components.</span></li>
          </ul>
        </div>
      </article>

      <article class="role">
        <div class="role-meta">
          <span class="dates">Apr 2023 — Dec 2024</span>
          <span class="fact">6 direct reports</span>
          <span class="fact">Cloud-native migration</span>
        </div>
        <div class="role-body">
          <div class="title">Lead Software Engineer</div>
          <p class="desc">
            Led six direct reports in delivering microservice architecture and
            cloud-native deployment practices across Guidepoint&rsquo;s engineering
            organization.
          </p>
          <ul class="actions-list">
            <li><span class="num">01</span><span>Spearheaded company-wide platform migration to containerized, cloud-native workflows &mdash; deployment standards, CI/CD integration, and operational runbooks that enabled <span class="clay">10+ teams and 20+ services</span> to ship on Azure Kubernetes Service.</span></li>
            <li><span class="num">02</span><span>Architected and delivered an <strong>Identity Verification system</strong> integrated directly into Guidepoint&rsquo;s core CRM &mdash; strengthening data integrity across <span class="clay">60,000+ in-network advisors</span>.</span></li>
            <li><span class="num">03</span><span>Designed and implemented a company-wide <strong>notes management service</strong>, unifying how all employees manage projects, advisors, and client interactions.</span></li>
            <li><span class="num">04</span><span>Built a <strong>mail-hook service</strong> automating note creation from inbound emails using Azure Event Grid, Graph API, and Service Bus &mdash; eliminating manual data entry on a high-frequency workflow.</span></li>
          </ul>
        </div>
      </article>
    </div>

    <!-- TOUR 2 — SWITCH -->
    <div class="tour">
      <div class="tour-band">
        <div class="idx"></div>
        <div class="org">
          <span class="name">Switch, Inc.</span>
          <span class="place">Las Vegas, NV</span>
        </div>
        <div class="dates">Jun 2017 — Apr 2023</div>
      </div>

      <article class="role">
        <div class="role-meta">
          <span class="dates">Jul 2021 — Apr 2023</span>
          <span class="fact">Reported to CTO &amp; EVP</span>
          <span class="fact">Strategic programs</span>
        </div>
        <div class="role-body">
          <div class="title">Technical Project Manager</div>
          <p class="desc">
            Applied technical expertise to strategic company initiatives under the
            direction of the CTO and EVP of Strategy.
          </p>
          <ul class="actions-list">
            <li><span class="num">01</span><span>Coordinated delivery of Switch&rsquo;s <strong>first iOS mobile application</strong> with a third-party development team &mdash; doubled productivity at shipping &amp; receiving locations upon release.</span></li>
            <li><span class="num">02</span><span>Served as program lead for the <strong>Power Program</strong>, identifying efficiencies and systematizing how Switch forecasts, purchases, and sells power across its data-center portfolio.</span></li>
            <li><span class="num">03</span><span>Led weekly Portfolio Command meetings with senior leadership, providing visibility and coordination across strategic objectives.</span></li>
            <li><span class="num">04</span><span>Managed personnel, contracts, and facilities integration following the acquisition of Data Foundry.</span></li>
            <li><span class="num">05</span><span>Drove implementation of data analytics and process mining capabilities to improve operational decision-making.</span></li>
          </ul>
        </div>
      </article>

      <article class="role">
        <div class="role-meta">
          <span class="dates">Feb 2020 — Jul 2021</span>
          <span class="fact">Senior IC · back-end</span>
