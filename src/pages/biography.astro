---
import InnerLayout from '../layouts/InnerLayout.astro';
---
<InnerLayout title="Biography" activePage="biography">
  <style is:global>
    .page-intro {
      max-width: 1280px;
      margin: 32px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 32px;
      align-items: end;
    }
    .page-intro .eyebrow { margin-bottom: 12px; }
    .page-intro h1 {
      font-family: var(--font-sans);
      font-size: 56px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.025em;
      line-height: 1;
      color: var(--ink-900);
    }
    .page-intro .dek {
      max-width: 60ch;
      margin-top: 18px;
      color: var(--ink-700);
      font-size: var(--fs-16);
      line-height: 1.55;
      text-wrap: pretty;
    }
    .page-intro .legend {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--label-mono);
      text-align: right;
      line-height: 1.7;
    }
    .page-intro .legend .num { color: var(--ink-800); }

    .map-card {
      max-width: 1280px;
      margin: 40px auto 0;
      padding: 0 24px;
    }
    .map-frame {
      position: relative;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--r-lg);
      overflow: hidden;
      box-shadow: var(--shadow-sm);
    }
    .map-band {
      display: flex; align-items: center; justify-content: space-between;
      padding: 10px 18px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
    }
    .map-band .left { display: inline-flex; align-items: center; gap: 10px; }
    .map-band .right .sep { color: var(--ink-300); padding: 0 8px; }

    .chart-wrap {
      position: relative;
      background: var(--site-paper-deep);
      background-image:
        linear-gradient(rgba(42,40,36,0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(42,40,36,0.05) 1px, transparent 1px);
      background-size: 20px 20px;
      padding: 24px 16px 16px;
    }
    .chart {
      width: 100%;
      height: auto;
      display: block;
      color: var(--ink-700);
    }

    .chart .grid-major { stroke: rgba(42,40,36,0.08); stroke-width: 1; }
    .chart .grid-axis-label { font-family: var(--font-mono); font-size: 9px; fill: var(--ink-500); letter-spacing: 0.06em; text-transform: uppercase; }
    .chart .us-outline {
      fill: var(--ink-50);
      stroke: var(--ink-400);
      stroke-width: 1.1;
      stroke-linejoin: round;
      stroke-linecap: round;
    }
    .chart .us-outline-shadow { fill: rgba(74, 103, 65, 0.05); stroke: none; }
    .chart .route { fill: none; stroke: var(--clay-400); stroke-width: 1.5; stroke-dasharray: 4 4; opacity: 0.85; }
    .chart .route-glow { fill: none; stroke: var(--clay-400); stroke-width: 6; opacity: 0.12; stroke-linecap: round; }
    .chart .bearing-label { font-family: var(--font-mono); font-size: 9px; fill: var(--clay-700); letter-spacing: 0.05em; text-transform: uppercase; }
    .chart .marker .ring { fill: var(--card-bg); stroke: var(--ink-900); stroke-width: 1.2; }
    .chart .marker .ring-active { fill: var(--moss-500); stroke: var(--moss-700); }
    .chart .marker .num { font-family: var(--font-mono); font-weight: 600; font-size: 10px; fill: var(--ink-900); text-anchor: middle; }
    .chart .marker .num-on { fill: var(--ink-50); }
    .chart .marker .pin-label { font-family: var(--font-mono); font-size: 9.5px; font-weight: 600; fill: var(--ink-900); letter-spacing: 0.04em; }
    .chart .marker .pin-coord { font-family: var(--font-mono); font-size: 8px; fill: var(--ink-500); letter-spacing: 0.04em; }
    .chart .marker .pin-year { font-family: var(--font-mono); font-size: 8.5px; fill: var(--clay-600); letter-spacing: 0.06em; }
    .chart .compass { fill: var(--ink-700); }
    .chart .compass-bg { fill: var(--card-bg); stroke: var(--ink-300); stroke-width: 1; }
    .chart .compass-label { font-family: var(--font-mono); font-size: 9px; fill: var(--ink-700); text-anchor: middle; font-weight: 600; }
    .chart .scalebar-line { stroke: var(--ink-700); stroke-width: 1.5; }
    .chart .scalebar-tick { stroke: var(--ink-700); stroke-width: 1; }
    .chart .scalebar-label { font-family: var(--font-mono); font-size: 8.5px; fill: var(--ink-700); }

    .chapters {
      max-width: 1280px;
      margin: 64px auto 0;
      padding: 0 24px;
    }
    .chapters-head {
      display: flex; align-items: baseline; gap: 16px;
      padding-bottom: 14px;
      margin-bottom: 32px;
      border-bottom: 1px solid var(--rule-strong);
    }
    .chapters-head h2 {
      font-family: var(--font-sans);
      font-size: 26px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.02em;
      color: var(--ink-900);
    }
    .chapters-head .meta {
      margin-left: auto;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      text-transform: uppercase;
      letter-spacing: var(--tr-caps);
      color: var(--label-mono);
    }

    .chapter {
      display: grid;
      grid-template-columns: 280px 1fr;
      gap: 48px;
      padding: 32px 0 36px;
      border-top: 1px solid var(--border-subtle);
      position: relative;
    }
    .chapter:first-of-type { border-top: 1px solid var(--rule-strong); }

    .chapter .meta-col { position: sticky; top: 24px; align-self: start; }
    .chapter .marker {
      display: flex; align-items: center; gap: 10px;
      margin-bottom: 16px;
    }
    .chapter .marker .num {
      display: inline-flex; align-items: center; justify-content: center;
      width: 32px; height: 32px;
      border-radius: 50%;
      background: var(--moss-500);
      color: var(--ink-50);
      font-family: var(--font-mono);
      font-weight: var(--fw-semibold);
      font-size: var(--fs-13);
    }
    .chapter .marker .target {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
    }
    .chapter .loc {
      font-family: var(--font-sans);
      font-size: 28px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.02em;
      line-height: 1.05;
      color: var(--ink-900);
      margin-bottom: 8px;
    }
    .chapter .state {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-600);
    }
    .chapter .meta-list {
      margin-top: 22px;
      display: grid;
      grid-template-columns: auto 1fr;
      gap: 6px 14px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
    }
    .chapter .meta-list .k { color: var(--ink-500); }
    .chapter .meta-list .v { color: var(--ink-800); }
    .chapter .meta-list .v.accent { color: var(--clay-600); }

    .chapter .body { padding-top: 4px; }
    .chapter .role-tag {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 0 0 12px;
      color: var(--clay-600);
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      border-bottom: 1px solid var(--clay-100);
      margin-bottom: 18px;
    }
    .chapter .body p {
      margin: 0 0 14px;
      font-size: var(--fs-16);
      line-height: 1.6;
      color: var(--ink-700);
      max-width: 65ch;
      text-wrap: pretty;
    }
    .chapter .body p:last-child { margin-bottom: 0; }

    .chapter .highlights {
      margin-top: 20px;
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 12px;
      max-width: 880px;
    }
    .chapter .hi {
      background: var(--site-paper-deep);
      border-left: 2px solid var(--moss-400);
      padding: 12px 14px;
      border-radius: var(--r-sm);
    }
    .chapter .hi .k {
      font-family: var(--font-mono);
      font-size: var(--fs-10);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
      margin-bottom: 4px;
    }
    .chapter .hi .v {
      font-family: var(--font-mono);
      font-size: var(--fs-13);
      font-weight: var(--fw-semibold);
      color: var(--ink-900);
    }
    .chapter .hi .v .unit { font-size: var(--fs-11); color: var(--ink-500); font-weight: var(--fw-regular); letter-spacing: var(--tr-wide); }

    .bio-cta {
      max-width: 1280px;
      margin: 48px auto 0;
      padding: 0 24px;
    }
    .bio-cta-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      padding: 32px;
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--r-lg);
    }
    .bio-cta .lead {
      font-family: var(--font-sans);
      font-size: 22px;
      letter-spacing: -0.015em;
      color: var(--ink-900);
      font-weight: var(--fw-medium);
    }
    .bio-cta .sub {
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--ink-500);
      margin-top: 4px;
    }
    .bio-cta .actions { display: flex; gap: 12px; }
    .bio-cta a {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 12px 18px;
      background: var(--moss-500);
      color: var(--ink-50);
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      border-radius: var(--r-sm);
      border: 1px solid var(--moss-700);
      transition: background var(--dur-fast) var(--ease-out);
    }
    .bio-cta a.secondary {
      background: var(--card-bg);
      color: var(--ink-800);
      border: 1px solid var(--card-border);
    }
    .bio-cta a:hover { background: var(--moss-600); border-bottom-color: var(--moss-700); }
    .bio-cta a.secondary:hover { background: var(--card-bg-deep); }
    .bio-cta a::after { content: '→'; transition: transform var(--dur-fast) var(--ease-out); }
    .bio-cta a:hover::after { transform: translateX(3px); }

    @media (max-width: 880px) {
      .chapter { grid-template-columns: 1fr; gap: 20px; }
      .chapter .meta-col { position: static; }
      .page-intro { grid-template-columns: 1fr; }
      .page-intro h1 { font-size: 40px; }
      .page-intro .legend { text-align: left; }
      .bio-cta-inner { flex-direction: column; align-items: flex-start; }
    }
  </style>

  <!-- Intro -->
  <header class="page-intro">
    <div>
      <div class="eyebrow">02 / Biography</div>
      <h1>The route map.</h1>
      <p class="dek">
        Four chapters. One story, plotted by where it happened.
        Islamorada to Tallahassee, Virginia to Las Vegas &mdash; from a Florida Keys
        swim team, through six years in Naval Special Warfare intelligence, into
        a decade of building software and the teams that ship it.
      </p>
    </div>
    <div class="legend">
      <div><span class="num">01</span> · Islamorada, FL</div>
      <div><span class="num">02</span> · Tallahassee, FL</div>
      <div><span class="num">03</span> · Virginia Beach, VA</div>
      <div><span class="num">04</span> · Las Vegas, NV</div>
    </div>
  </header>

  <!-- Map -->
  <section class="map-card" aria-label="Route map">
