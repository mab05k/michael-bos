          <!-- Compass rose -->
          <g transform="translate(75,80)">
            <circle class="compass-bg" cx="0" cy="0" r="24"></circle>
            <path class="compass" d="M0,-20 L4,-2 L0,0 L-4,-2 Z" fill-opacity="0.85"></path>
            <path class="compass" d="M0,20 L4,2 L0,0 L-4,2 Z" fill-opacity="0.25"></path>
            <text class="compass-label" x="0" y="-28">N</text>
          </g>

          <!-- Scale bar -->
          <g transform="translate(990,530)">
            <line class="scalebar-line" x1="0" y1="0" x2="152" y2="0"></line>
            <line class="scalebar-tick" x1="0" y1="-3" x2="0" y2="3"></line>
