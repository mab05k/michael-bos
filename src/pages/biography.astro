            <path class="route-glow" d="M 892.2,506.5 L 822.7,401.6 L 980.4,279.9 L 236.3,292.8"></path>
            <path class="route" d="M 892.2,506.5 L 822.7,401.6 L 980.4,279.9 L 236.3,292.8">
