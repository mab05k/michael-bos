/* =========================================================
   LAYOUT — full-screen stage
   ========================================================= */

.stage {
  position: fixed; inset: 0;
  display: grid;
  grid-template-rows: auto 1fr auto;
  background: var(--bone);
  color: var(--ink);
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1), color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
/* ── SiteHeader inside the stage ───────────────────────────
   Transparent background, no blur — stage color shows through.
   Nav colors and brand inherit from the active chapter theme
   and transition with it at the same timing as the stage.
   ─────────────────────────────────────────────────────────── */
.stage .site-header {
  position: relative;
  top: auto;
  background: transparent;
  backdrop-filter: none;
  -webkit-backdrop-filter: none;
  border-bottom-color: var(--line);
  transition: border-color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.stage .site-header-inner {
  height: auto;
}
.stage .brand .wm {
  color: var(--ink);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.stage .brand .slash {
  color: var(--accent);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.stage .brand:hover .wm { color: var(--accent); }
.stage .topnav-link {
  color: var(--fade);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1),
              background 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.stage .topnav-link:hover { color: var(--ink); }
.stage .topnav-link.is-active {
  color: var(--accent);
  font-weight: 600;
  background: color-mix(in oklab, var(--accent) 13%, transparent);
}
.topbar-right {
  display: flex; align-items: center; gap: 18px; flex: 0 0 auto;
}
.loc {
  display: inline-flex; align-items: center; gap: 7px;
  font-family: var(--font-mono); font-size: 11px;
  letter-spacing: 0.06em; color: var(--fade);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.loc .pin {
  width: 8px; height: 8px;
  border: 1.5px solid var(--accent); border-radius: 50%;
  position: relative;
  transition: border-color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.loc .pin::after {
  content: ""; position: absolute; inset: 2px;
  background: var(--accent); border-radius: 50%;
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.chapter-count {
  font-family: var(--font-mono); font-size: 12px; color: var(--fade);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.chapter-count b {
  color: var(--accent); font-weight: 700;
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.stage::before {
  content: ""; position: absolute; inset: 0; pointer-events: none;
  background: var(--wash);
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1);
  z-index: 0;
}

/* =========================================================
   STAGE BODY
   ========================================================= */

.stage-body {
  position: relative; z-index: 2;
  min-height: 0;
  padding: 12px 40px;
  display: grid;
  place-items: safe center;
  overflow-y: auto;
  overflow-x: hidden;
  scrollbar-width: thin;
  scrollbar-color: var(--line-2) transparent;
}
.stage-body::-webkit-scrollbar { width: 8px; }
.stage-body::-webkit-scrollbar-thumb { background: var(--line-2); border-radius: 8px; }

/* =========================================================
   TIMELINE RAIL (bottom)
   ========================================================= */

.rail {
  position: relative; z-index: 5;
  padding: 0 40px 22px;
}
.rail-track {
  position: relative;
  display: grid;
  grid-auto-flow: column;
  grid-auto-columns: 1fr;
  align-items: start;
  padding-top: 26px;
}
.rail-line {
  position: absolute; top: 32px; height: 2px;
  background: var(--line-2); border-radius: 2px;
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.rail-progress {
  position: absolute; top: 32px; height: 2px;
  background: var(--accent); border-radius: 2px;
  transition: width 460ms cubic-bezier(0.2,0.7,0.1,1),
              background 460ms cubic-bezier(0.2,0.7,0.1,1);
}

.node {
  position: relative;
  background: none; border: 0; cursor: pointer;
  display: flex; flex-direction: column; align-items: center; gap: 2px;
  padding: 0; text-align: center; font-family: inherit;
}
.node-dot {
  position: relative; z-index: 2;
  width: 14px; height: 14px; border-radius: 50%;
  background: var(--bone);
  border: 2px solid var(--line-2);
  margin-bottom: 12px;
  transition: border-color 460ms cubic-bezier(0.2,0.7,0.1,1),
              background 460ms cubic-bezier(0.2,0.7,0.1,1),
              transform 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.node:hover .node-dot { border-color: var(--accent); }
.node.is-active .node-dot {
  border-color: var(--accent); background: var(--accent);
  transform: scale(1.25);
  box-shadow: 0 0 0 5px color-mix(in oklab, var(--accent) 22%, transparent);
}
.node.is-done .node-dot { border-color: var(--accent); }

.node-year {
  font-family: var(--font-mono); font-size: 12px; font-weight: 500;
  letter-spacing: 0.04em; color: var(--fade);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.node.is-active .node-year { color: var(--accent); }
.node-label {
  font-family: var(--font-display); font-size: 13px; font-weight: 500;
  color: var(--sub); white-space: nowrap;
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.node.is-active .node-label { color: var(--ink); font-weight: 600; }

.rail-nav {
  position: absolute; right: 40px; top: -2px;
  display: flex; gap: 8px;
}
.arrow {
  width: 38px; height: 38px; border-radius: 999px;
  border: 1.5px solid var(--line-2); background: transparent;
  color: var(--ink); cursor: pointer;
  display: grid; place-items: center;
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1),
              border-color 460ms cubic-bezier(0.2,0.7,0.1,1),
              opacity 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.arrow:hover { border-color: var(--accent); color: var(--accent); }
.arrow:disabled { opacity: 0.32; cursor: default; }
.arrow svg { width: 18px; height: 18px; }

/* =========================================================
   CHAPTER CONTENT
   ========================================================= */

.chapter {
  width: 100%;
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
  gap: 64px;
  align-items: center;
  max-width: 1240px; margin: auto;
}
.ch-left { min-width: 0; }
.ch-right { min-width: 0; display: flex; flex-direction: column; gap: 16px; }

.ch-kicker {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: var(--font-mono); font-size: 12px;
  letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.ch-kicker .yr { color: var(--fade); transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); }
.ch-num {
  font-family: var(--font-mono); font-weight: 700; font-size: 12px;
  color: var(--on-accent); background: var(--accent);
  padding: 3px 8px; border-radius: 4px;
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1),
              color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.ch-title {
  font-family: var(--font-display); font-weight: 600;
  font-size: clamp(38px, 5.2vw, 62px); line-height: 1.02;
  letter-spacing: -0.025em; color: var(--ink);
  margin: 22px 0 0; text-wrap: balance; max-width: 16ch;
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.ch-body { margin-top: 22px; max-width: 60ch; }
.ch-body p {
  font-size: 17px; line-height: 1.66; color: var(--sub);
  margin: 0 0 16px;
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.ch-body p:last-child { margin-bottom: 0; }
.ch-body strong { color: var(--ink); font-weight: 600; }

.ch-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 28px; }
.ch-chip {
  display: inline-flex; align-items: center; gap: 5px;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--accent);
  padding: 6px 12px;
  border-radius: 4px;
  border: 1px solid color-mix(in oklab, var(--accent) 42%, transparent);
  background: color-mix(in oklab, var(--accent) 9%, transparent);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1),
              border-color 460ms cubic-bezier(0.2,0.7,0.1,1),
              background 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.ch-chip svg { flex-shrink: 0; }

.icon-credits {
  font-family: var(--font-mono); font-size: 9px; letter-spacing: 0.04em;
  color: var(--fade); opacity: 0.55; margin: 6px 0 0; text-align: center;
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1);
  min-height: 1em;
}
.icon-credits a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }

.tech-stack { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 6px; }

/* generic seal monogram */
.seal {
  width: 54px; height: 54px; flex-shrink: 0; border-radius: 50%;
  border: 2px solid var(--accent2); color: var(--accent2);
  display: grid; place-items: center;
  font-family: var(--font-mono); font-weight: 700; font-size: 13px;
  letter-spacing: 0.02em;
  transition: border-color 460ms cubic-bezier(0.2,0.7,0.1,1),
              color 460ms cubic-bezier(0.2,0.7,0.1,1);
}

/* =========================================================
   ENTRANCE ANIMATION
   ========================================================= */

@media (prefers-reduced-motion: no-preference) {
  .stage[data-anim="in"] .ch-left > * {
    opacity: 0; transform: translateY(14px);
    animation: rise 560ms cubic-bezier(0.2,0.7,0.1,1) forwards;
  }
  .stage[data-anim="in"] .ch-right {
    opacity: 0; transform: translateY(18px);
    animation: rise 620ms cubic-bezier(0.2,0.7,0.1,1) 80ms forwards;
  }
  .stage[data-anim="in"] .ch-left > *:nth-child(1) { animation-delay: 40ms; }
  .stage[data-anim="in"] .ch-left > *:nth-child(2) { animation-delay: 110ms; }
  .stage[data-anim="in"] .ch-left > *:nth-child(3) { animation-delay: 180ms; }
  .stage[data-anim="in"] .ch-left > *:nth-child(4) { animation-delay: 250ms; }
}
@keyframes rise { to { opacity: 1; transform: none; } }

/* =========================================================
   SIGNATURE DEVICES
   ========================================================= */

/* Keys — photo carousel */
.keys-carousel {
  position: relative; height: 300px; border-radius: 14px;
  overflow: hidden; border: 1px solid var(--line);
  box-shadow: 0 12px 32px rgba(0,0,0,0.22);
}
.kc-slides { position: absolute; inset: 0; }
.kc-slide {
  position: absolute; inset: 0;
  opacity: 0; transition: opacity 480ms cubic-bezier(0.2,0.7,0.1,1);
}
.kc-slide.is-active { opacity: 1; }
.kc-slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
.kc-tag {
  position: absolute; left: 14px; bottom: 14px;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.04em;
  color: #EAF6F7; padding: 5px 10px; border-radius: 4px;
  background: rgba(10,30,34,0.62); backdrop-filter: blur(4px);
}
.kc-arrow {
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 34px; height: 34px; border-radius: 999px;
  border: 1.5px solid rgba(255,255,255,0.35);
  background: rgba(10,30,34,0.48); backdrop-filter: blur(4px);
  color: #EAF6F7; cursor: pointer;
  display: grid; place-items: center;
  transition: background 200ms, border-color 200ms, opacity 200ms;
  z-index: 4;
}
.kc-arrow:hover { background: rgba(10,30,34,0.72); border-color: rgba(255,255,255,0.62); }
.kc-arrow:disabled { opacity: 0.28; cursor: default; }
.kc-arrow svg { width: 16px; height: 16px; }
.kc-prev { left: 10px; }
.kc-next { right: 10px; }
.kc-dots {
  position: absolute; bottom: 14px; right: 14px;
  display: flex; gap: 6px; z-index: 4;
}
.kc-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: rgba(255,255,255,0.38);
  transition: background 300ms, transform 300ms;
}
.kc-dot.is-active { background: #fff; transform: scale(1.3); }

/* FSU — degree card */
.degree-card {
  display: flex; align-items: center; gap: 18px;
  padding: 26px 28px; border-radius: 14px;
  background: linear-gradient(180deg, var(--accent), color-mix(in oklab, var(--accent) 78%, #000));
  border: 1px solid color-mix(in oklab, var(--accent2) 45%, transparent);
  box-shadow: 0 12px 32px rgba(0,0,0,0.22);
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.degree-card .fsu-logo { width:72px; height:72px; flex-shrink:0; object-fit:contain; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.4)); }
.dc-deg { font-family: var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color: var(--accent2); font-weight: bold; }
.dc-school { font-family: var(--font-display); font-weight:600; font-size:21px; color:#F6EFE1; margin:5px 0 3px; letter-spacing:-0.01em; }
.dc-meta { font-family: var(--font-mono); font-size:12px; color:rgba(246,239,225,0.78); letter-spacing:0.03em; }
.dc-rule { height:4px; margin-top:14px; border-radius:2px; background: linear-gradient(90deg, var(--accent) 0 50%, var(--accent2) 50% 100%); transition: background 460ms cubic-bezier(0.2,0.7,0.1,1); }

/* Navy — service record */
.service-card {
  border-radius: 14px; border: 1px solid var(--line-2);
  background: var(--device-bg); padding: 26px 28px;
  box-shadow: 0 12px 32px rgba(0,0,0,0.45);
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1),
              border-color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.service-card-head {
  display:flex; align-items:center; gap:16px;
  padding-bottom:18px; margin-bottom:4px;
  border-bottom:1px solid rgba(216,178,62,0.22);
}
.navy-emblem { width:56px; height:56px; flex-shrink:0; object-fit:contain; filter: drop-shadow(0 2px 6px rgba(0,0,0,0.5)); }
.service-title { font-family: var(--font-display); font-weight:600; font-size:15px; color: var(--device-ink); margin-top:0px; }
.service-subtitle { font-family: var(--font-display); font-weight:500; font-size:12px; color: var(--device-ink); margin-top:0px; }
.service-grid { display:flex; flex-direction:column; gap:0; }
.service-line {
  display:grid; grid-template-columns:92px 1fr; gap:16px; align-items:baseline;
  padding:13px 0; border-bottom:1px solid rgba(216,178,62,0.18);
}
.service-line:last-child { border-bottom:0; }
.service-k { font-family: var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color: var(--accent); }
.service-v { font-family: var(--font-body); font-size:15px; color: var(--device-ink); }
.deploy-tally {
  display:flex; align-items:center; gap:16px; justify-content: end;
  padding-top:18px;
  border-top:1px solid rgba(216,178,62,0.22);
}
.deploy-marks { display:flex; gap:10px; }
.deploy-mark {
  width:12px; height:12px;
  clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
  background: var(--accent);
}
.deploy-label {
  font-family: var(--font-mono); font-size:11px;
  letter-spacing:0.1em; text-transform:uppercase;
  color: var(--fade);
}

/* UNLV — ledger */
.ledger { border-radius:14px; border:1px solid var(--line-2); overflow:hidden; background: var(--sand); box-shadow:0 12px 32px rgba(0,0,0,0.12); transition: background 460ms cubic-bezier(0.2,0.7,0.1,1), border-color 460ms cubic-bezier(0.2,0.7,0.1,1); }
.ledger-head { display:flex; align-items:center; gap:16px; padding:18px 22px; background: color-mix(in oklab, var(--accent) 12%, transparent); border-bottom:1px solid var(--line-2); }
.ledger-head .seal { width:50px; height:50px; font-size:11px; border-color: var(--accent); color: var(--accent); }
.lh-deg { font-family: var(--font-mono); font-size:11px; letter-spacing:0.1em; text-transform:uppercase; color: var(--accent); }
.lh-school { font-family: var(--font-display); font-weight:600; font-size:17px; color: var(--ink); margin-top:3px; transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); }
.ledger-row { display:grid; grid-template-columns:1fr 26px 1fr; align-items:center; gap:12px; padding:14px 22px; border-bottom:1px solid var(--line); }
.ledger-row:last-child { border-bottom:0; }
.ledger-l { font-family: var(--font-body); font-size:14px; color: var(--fade); }
.ledger-l em { font-style:normal; text-decoration:line-through; text-decoration-color: var(--accent); }
.ledger-eq { font-family: var(--font-mono); color: var(--accent); text-align:center; font-size:15px; transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); }
.ledger-r { font-family: var(--font-body); font-size:14px; color: var(--ink); font-weight:500; transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); }

/* Tech — terminal */
.term { border-radius:14px; overflow:hidden; border:1px solid var(--line-2); box-shadow:0 12px 32px rgba(0,0,0,0.22); background: var(--device-bg); transition: background 460ms cubic-bezier(0.2,0.7,0.1,1); }
.term-bar { display:flex; align-items:center; gap:8px; padding:12px 16px; background:rgba(255,255,255,0.04); border-bottom:1px solid rgba(255,255,255,0.06); }
.tdot { width:11px; height:11px; border-radius:50%; }
.term-title { font-family: var(--font-mono); font-size:11px; color:rgba(234,217,190,0.6); margin-left:8px; letter-spacing:0.04em; }
.term-body { padding:20px 22px; font-family: var(--font-mono); font-size:13.5px; line-height:1.9; color: var(--device-ink); }
.term-body .dim { color:rgba(234,217,190,0.5); }
.term-body .acc { color: var(--accent2); }
.term-body .ok { color:#6FCB7F; }

/* Climb — carousel */
.climb-carousel {
  position:relative; height:300px; border-radius:14px;
  overflow:hidden; border:1px solid var(--line);
  box-shadow:0 16px 40px rgba(34,20,9,0.32);
}
.cc-slides { position:absolute; inset:0; }
.cc-slide {
  position:absolute; inset:0;
  opacity:0; transition:opacity 480ms cubic-bezier(0.2,0.7,0.1,1);
}
.cc-slide.is-active { opacity:1; }
.cc-slide img { width:100%; height:100%; object-fit:cover; object-position:center 30%; display:block; }
.cc-tag {
  position:absolute; left:14px; bottom:14px;
  font-family: var(--font-mono); font-size:11px; letter-spacing:0.04em;
  color:#F0E4D1; padding:5px 10px; border-radius:4px;
  background:rgba(20,14,9,0.55); backdrop-filter:blur(3px);
}

/* Climb — tick list */
.tick-list {
  border-radius:10px; border:1px solid var(--line);
  overflow:hidden; background:var(--sand);
  transition: background 460ms cubic-bezier(0.2,0.7,0.1,1), border-color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.tick-list-head {
  font-family: var(--font-mono); font-size:10px; letter-spacing:0.12em;
  text-transform:uppercase; color: var(--fade);
  padding:10px 16px 8px;
  border-bottom:1px solid var(--line);
  transition: color 460ms cubic-bezier(0.2,0.7,0.1,1), border-color 460ms cubic-bezier(0.2,0.7,0.1,1);
}
.tick-row {
  display:grid; grid-template-columns:1fr auto; gap:10px; align-items:baseline;
  padding:10px 16px; border-bottom:1px solid var(--line);
}
.tick-row:last-child { border-bottom:0; }
.tick-name { display:inline-flex; align-items:baseline; gap:6px; min-width:0; }
.tick-route { font-family: var(--font-display); font-size:14px; font-weight:600; color: var(--ink); transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); white-space:nowrap; }
.tick-area { font-family: var(--font-mono); font-size:11px; color: var(--fade); letter-spacing:0.02em; transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); white-space:nowrap; }
.tick-grade { font-family: var(--font-mono); font-size:12px; font-weight:700; color: var(--accent); transition: color 460ms cubic-bezier(0.2,0.7,0.1,1); }

/* =========================================================
   RESPONSIVE
   ========================================================= */

@media (max-width: 860px) {
  .topbar-right { display: none; }
  .stage-body { padding: 12px 20px; }
  .rail { padding: 0 20px 16px; }
  .rail-nav { right: 0; }
  .chapter { grid-template-columns: 1fr; gap: 28px; }
  .ch-right { display: none; }
  .ch-title { font-size: clamp(32px, 8vw, 48px); }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { transition-duration: 0ms !important; animation-duration: 0ms !important; }
}

/* =========================================================
   TICK LIST — CTA row
   ========================================================= */

.tick-list-count { color: var(--fade); font-weight: 400; }

.tick-cta {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; padding: 10px 16px;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--accent);
  background: color-mix(in oklab, var(--accent) 8%, transparent);
  border: 0; border-top: 1px solid var(--line);
  cursor: pointer;
  transition: background 160ms var(--ease-out), color 160ms var(--ease-out);
}
.tick-cta:hover { background: color-mix(in oklab, var(--accent) 15%, transparent); }
.tick-cta svg { flex-shrink: 0; transition: transform 160ms var(--ease-out); }
.tick-cta:hover svg { transform: translateX(3px); }

/* =========================================================
   TICK LOG PANEL (slide-out)
   ========================================================= */

.tick-panel {
  position: fixed; inset: 0; z-index: 200;
  pointer-events: none;
}
.tick-panel.is-open { pointer-events: all; }

.tp-backdrop {
  position: absolute; inset: 0;
  background: rgba(34,20,9,0);
  transition: background 320ms var(--ease-out);
}
.tick-panel.is-open .tp-backdrop { background: rgba(34,20,9,0.52); }

.tp-drawer {
  position: absolute; top: 0; right: 0; bottom: 0;
  width: min(460px, 100vw);
  background: var(--bone);
  border-left: 1px solid var(--line-2);
  box-shadow: -16px 0 56px rgba(34,20,9,0.32);
  display: flex; flex-direction: column;
  transform: translateX(100%);
  transition: transform 380ms cubic-bezier(0.2,0.7,0.1,1);
}
.tick-panel.is-open .tp-drawer { transform: translateX(0); }

.tp-head {
  display: flex; align-items: flex-start; justify-content: space-between; gap: 16px;
  padding: 22px 24px 18px;
  border-bottom: 1px solid var(--line);
  flex-shrink: 0;
}
.tp-title {
  font-family: var(--font-display); font-weight: 600; font-size: 18px;
  color: var(--ink); letter-spacing: -0.01em;
}
.tp-sub {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.1em;
  text-transform: uppercase; color: var(--fade); margin-top: 4px;
}
.tp-close {
  width: 32px; height: 32px; flex-shrink: 0; border-radius: 6px;
  border: 1px solid var(--line); background: transparent;
  color: var(--fade); cursor: pointer;
  display: grid; place-items: center;
  transition: border-color 160ms, color 160ms, background 160ms;
}
.tp-close:hover {
  border-color: var(--accent); color: var(--accent);
  background: color-mix(in oklab, var(--accent) 9%, transparent);
}

.tp-body {
  flex: 1; overflow-y: auto; overflow-x: hidden;
  scrollbar-width: thin; scrollbar-color: var(--line-2) transparent;
  display: flex; flex-direction: column;
}
.tp-body::-webkit-scrollbar { width: 6px; }
.tp-body::-webkit-scrollbar-thumb { background: var(--line-2); border-radius: 4px; }

.tp-list { flex: 1; }

.tp-row {
  display: grid; grid-template-columns: 1fr auto; gap: 12px; align-items: center;
  padding: 11px 24px; border-bottom: 1px solid var(--line);
  text-decoration: none; color: inherit;
  transition: background 120ms;
}
.tp-row:hover { background: color-mix(in oklab, var(--accent) 7%, transparent); }
.tp-row:last-child { border-bottom: 0; }
.tp-row-left { min-width: 0; }
.tp-route {
  font-family: var(--font-display); font-size: 14px; font-weight: 600; color: var(--ink);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block;
}
.tp-meta {
  font-family: var(--font-mono); font-size: 10px; letter-spacing: 0.04em;
  color: var(--fade); margin-top: 2px; display: block;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.tp-right { display: flex; flex-direction: column; align-items: flex-end; gap: 2px; flex-shrink: 0; }
.tp-grade { font-family: var(--font-mono); font-size: 12px; font-weight: 700; color: var(--accent); }
.tp-date { font-family: var(--font-mono); font-size: 10px; color: var(--fade); white-space: nowrap; }

.tp-more {
  display: block; width: 100%; padding: 14px 24px; flex-shrink: 0;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--accent); background: transparent; border: 0; border-top: 1px solid var(--line);
  cursor: pointer;
  transition: background 160ms var(--ease-out);
}
.tp-more:hover { background: color-mix(in oklab, var(--accent) 9%, transparent); }
.tp-more[hidden] { display: none; }

.tp-empty {
  padding: 48px 24px; text-align: center;
  font-family: var(--font-mono); font-size: 11px; letter-spacing: 0.06em;
  color: var(--fade); text-transform: uppercase;
}
</style>

<script is:inline>
(function() {
  var NP = 'https://thenounproject.com';
  var CHAPTERS = [
    { theme: 'keys', credits: 'Icons by <a href="'+NP+'/browse/icons/term/florida/" target="_blank" rel="noopener">Michael Thompson</a>, <a href="'+NP+'/browse/icons/term/diving/" target="_blank" rel="noopener">Olifernes Tejeros</a>, <a href="'+NP+'/browse/icons/term/hammerhead-shark/" target="_blank" rel="noopener">T. Kiefer Robertson</a>, <a href="'+NP+'/browse/icons/term/hurricane/" target="_blank" rel="noopener">Lewen Design</a>, <a href="'+NP+'/browse/icons/term/swimmer/" target="_blank" rel="noopener">Pixelz Studio</a> via <a href="'+NP+'" target="_blank" rel="noopener">Noun Project</a> (CC BY 3.0)' },
    { theme: 'fsu',   credits: 'Florida by <a href="'+NP+'/browse/icons/term/florida/" target="_blank" rel="noopener">Michael Thompson</a> &middot; Theta by <a href="'+NP+'/browse/icons/term/theta/" target="_blank" rel="noopener">doniprayogo</a> &middot; X by <a href="'+NP+'/browse/icons/term/x/" target="_blank" rel="noopener">Imam</a> via <a href="'+NP+'" target="_blank" rel="noopener">Noun Project</a> (CC BY 3.0) &middot; Graduation cap: <a href="https://lucide.dev" target="_blank" rel="noopener">Lucide</a> (ISC)' },
    { theme: 'navy',  credits: '' },
    { theme: 'tech',  credits: '' },
    { theme: 'unlv',  credits: 'Nevada by <a href="'+NP+'/browse/icons/term/nevada/" target="_blank" rel="noopener">Tyler Gobberdiel</a> via <a href="'+NP+'" target="_blank" rel="noopener">Noun Project</a> (CC BY 3.0) &middot; Chart &amp; Boxes: <a href="https://lucide.dev" target="_blank" rel="noopener">Lucide</a> (ISC)' },
    { theme: 'climb', credits: '' },
  ];
  var N = CHAPTERS.length;
  var edge = 100 / (2 * N);
  var span = 100 - 2 * edge;

  var stage = document.getElementById('stage');
  var stageBody = document.getElementById('stage-body');
  var chapCurrent = document.getElementById('chap-current');
  var iconCredits = document.getElementById('icon-credits');
  var railLine = document.getElementById('rail-line');
  var railProgress = document.getElementById('rail-progress');
  var prevBtn = document.getElementById('prev-btn');
  var nextBtn = document.getElementById('next-btn');
  var nodes = document.querySelectorAll('.node[data-idx]');
  var slides = document.querySelectorAll('.chapter[id^="ch-"]');

  // Set fixed rail line bounds
  railLine.style.left = edge + '%';
  railLine.style.right = edge + '%';

  // Restore saved chapter
  var i = 0;
  try {
    var saved = Number(localStorage.getItem('bio-chapter'));
    if (Number.isFinite(saved) && saved >= 0 && saved < N) i = saved;
  } catch(e) {}

  function update(animate) {
    try { localStorage.setItem('bio-chapter', String(i)); } catch(e) {}

    // Theme
    stage.setAttribute('data-theme', CHAPTERS[i].theme);

    // Entrance animation re-trigger
    if (animate) {
      stage.setAttribute('data-anim', 'out');
      requestAnimationFrame(function() {
        requestAnimationFrame(function() {
          stage.setAttribute('data-anim', 'in');
        });
      });
    } else {
      stage.setAttribute('data-anim', 'in');
    }

    // Chapter count
    chapCurrent.textContent = String(i + 1).padStart(2, '0');

    // Rail progress
    var progress = N > 1 ? (i / (N - 1)) * span : 0;
    railProgress.style.left = edge + '%';
    railProgress.style.width = progress + '%';

    // Nodes
    nodes.forEach(function(node, idx) {
      node.classList.toggle('is-active', idx === i);
      node.classList.toggle('is-done', idx < i);
      if (idx === i) { node.setAttribute('aria-current', 'step'); }
      else { node.removeAttribute('aria-current'); }
    });

    // Slides
    slides.forEach(function(slide, idx) {
      slide.style.display = idx === i ? '' : 'none';
    });

    // Arrows
    prevBtn.disabled = i === 0;
    nextBtn.disabled = i === N - 1;

    // Icon credits
    var credits = CHAPTERS[i].credits || '';
    iconCredits.innerHTML = credits;
    iconCredits.style.visibility = credits ? 'visible' : 'hidden';
  }

  function go(next) {
    var n = Math.max(0, Math.min(N - 1, next));
    if (n === i) return;
    i = n;
    update(true);
  }

  // Initial render (no animation flash)
  update(false);

  // Controls
  prevBtn.addEventListener('click', function() { go(i - 1); });
  nextBtn.addEventListener('click', function() { go(i + 1); });
  nodes.forEach(function(node) {
    node.addEventListener('click', function() { go(Number(node.dataset.idx)); });
  });

  // Keyboard
  window.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight' || e.key === 'ArrowDown') { e.preventDefault(); go(i + 1); }
    if (e.key === 'ArrowLeft'  || e.key === 'ArrowUp')   { e.preventDefault(); go(i - 1); }
  });
})();

// Keys photo carousel
(function() {
  var slides = document.querySelectorAll('.kc-slide');
  var dots   = document.querySelectorAll('.kc-dot[data-kc-dot]');
  var prev   = document.getElementById('kc-prev');
  var next   = document.getElementById('kc-next');
  if (!prev || !next || slides.length === 0) return;

  var current = 0;

  function show(n) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    current = n;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    prev.disabled = current === 0;
    next.disabled = current === slides.length - 1;
  }

  show(0);
  prev.addEventListener('click', function() { if (current > 0) show(current - 1); });
  next.addEventListener('click', function() { if (current < slides.length - 1) show(current + 1); });
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { show(Number(dot.dataset.kcDot)); });
  });
})();

// Climb photo carousel
(function() {
  var slides = document.querySelectorAll('.cc-slide');
  var dots   = document.querySelectorAll('.kc-dot[data-cc-dot]');
  var prev   = document.getElementById('cc-prev');
  var next   = document.getElementById('cc-next');
  if (!prev || !next || slides.length === 0) return;

  var current = 0;

  function show(n) {
    slides[current].classList.remove('is-active');
    dots[current].classList.remove('is-active');
    current = n;
    slides[current].classList.add('is-active');
    dots[current].classList.add('is-active');
    prev.disabled = current === 0;
    next.disabled = current === slides.length - 1;
  }

  show(0);
  prev.addEventListener('click', function() { if (current > 0) show(current - 1); });
  next.addEventListener('click', function() { if (current < slides.length - 1) show(current + 1); });
  dots.forEach(function(dot) {
    dot.addEventListener('click', function() { show(Number(dot.dataset.ccDot)); });
  });
})();

// Tick log panel
(function() {
  var dataEl = document.getElementById('tick-data');
  var TICKS = dataEl ? JSON.parse(dataEl.textContent || '[]') : [];
  var BATCH = 25;
  var shown = 0;

  var panel    = document.getElementById('tick-panel');
  var backdrop = document.getElementById('tp-backdrop');
  var list     = document.getElementById('tp-list');
  var moreBtn  = document.getElementById('tp-more');
  var closeBtn = document.getElementById('tp-close');
  var ctaBtn   = document.getElementById('tick-cta');

  if (!panel || !ctaBtn) return;

  function esc(s) {
    return String(s)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderBatch() {
    var end = Math.min(shown + BATCH, TICKS.length);
    var frag = document.createDocumentFragment();
    for (var j = shown; j < end; j++) {
      var t = TICKS[j];
      var a = document.createElement('a');
      a.className = 'tp-row';
      a.href = t.url || '#';
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.innerHTML =
        '<div class="tp-row-left">'
        + '<span class="tp-route">' + esc(t.name) + '</span>'
        + (t.area ? '<span class="tp-meta">' + esc(t.area) + '</span>' : '')
        + '</div>'
        + '<div class="tp-right">'
        + '<span class="tp-grade">' + esc(t.grade) + '</span>'
        + (t.date ? '<span class="tp-date">' + esc(t.date) + '</span>' : '')
        + '</div>';
      frag.appendChild(a);
    }
    list.appendChild(frag);
    shown = end;
    if (moreBtn) moreBtn.hidden = shown >= TICKS.length;
  }

  function open() {
    if (shown === 0) {
      if (TICKS.length === 0) {
        list.innerHTML = '<div class="tp-empty">No ticks found.</div>';
        if (moreBtn) moreBtn.hidden = true;
      } else {
        renderBatch();
      }
    }
    panel.classList.add('is-open');
    panel.setAttribute('aria-hidden', 'false');
    if (closeBtn) closeBtn.focus();
  }

  function close() {
    panel.classList.remove('is-open');
    panel.setAttribute('aria-hidden', 'true');
    ctaBtn.focus();
  }

  ctaBtn.addEventListener('click', open);
  if (closeBtn) closeBtn.addEventListener('click', close);
  if (backdrop) backdrop.addEventListener('click', close);
  if (moreBtn) moreBtn.addEventListener('click', renderBatch);

  // Close when user navigates chapters
  document.querySelectorAll('.node[data-idx], #prev-btn, #next-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (panel.classList.contains('is-open')) close();
    });
  });

  // Keyboard: Escape closes; arrow keys blocked from chapter nav while panel is open
  document.addEventListener('keydown', function(e) {
    if (!panel.classList.contains('is-open')) return;
    if (e.key === 'Escape') { e.preventDefault(); close(); return; }
    if (e.key === 'ArrowRight' || e.key === 'ArrowLeft' ||
        e.key === 'ArrowDown'  || e.key === 'ArrowUp') {
      e.stopPropagation();
    }
  }, true); // capture phase — runs before the chapter nav listener
})();
</script>

</body>
</html>
