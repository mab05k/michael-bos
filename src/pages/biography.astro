          <span>Route map · Continental US · 1987 — present</span>
        </div>
        <div class="right" style="color: var(--ink-500);">
          <span>4 markers · 3 legs</span>
          <span class="sep" style="color: var(--ink-300);">·</span>
          <span>~5,200 mi traveled</span>
        </div>
      </div>
      <div class="chart-wrap">
        <svg class="chart" viewBox="-40 0 1240 550" xmlns="http://www.w3.org/2000/svg" aria-hidden="false">
