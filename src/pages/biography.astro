            <text x="714"  y="22" text-anchor="middle">90° W</text>
            <text x="904"  y="22" text-anchor="middle">80° W</text>
            <text x="1094" y="22" text-anchor="middle">70° W</text>
            <text x="24" y="128" text-anchor="end">45° N</text>
            <text x="24" y="223" text-anchor="end">40° N</text>
            <text x="24" y="318" text-anchor="end">35° N</text>
            <text x="24" y="413" text-anchor="end">30° N</text>
            <text x="24" y="508" text-anchor="end">25° N</text>
          </g>

