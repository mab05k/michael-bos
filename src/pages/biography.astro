---
import '../styles/shared.css';
import SiteHeader from '../components/SiteHeader.astro';

interface Tick {
  name: string;
  grade: string;
  area: string;
  date: string;
  url: string;
}

let ticks: Tick[] = [];

try {
  const res = await fetch('https://www.mountainproject.com/rss/user-ticks/200700760');
  if (res.ok) {
    const xml = await res.text();
    const itemRe = /<item>([\s\S]*?)<\/item>/g;
    let m: RegExpExecArray | null;
    while ((m = itemRe.exec(xml)) !== null) {
      const block = m[1];
      const rawTitle =
        (block.match(/<title><!\[CDATA\[(.*?)\]\]><\/title>/) || block.match(/<title>(.*?)<\/title>/) || [])[1] || '';
      const link = ((block.match(/<link>([\s\S]*?)<\/link>/) || [])[1] || '').trim();
      const pubDate = (block.match(/<pubDate>(.*?)<\/pubDate>/) || [])[1] || '';
      // Description may be CDATA or HTML-entity encoded — handle both
      let desc = (block.match(/<description><!\[CDATA\[([\s\S]*?)\]\]><\/description>/) || [])[1];
      if (!desc) {
        const raw = (block.match(/<description>([\s\S]*?)<\/description>/) || [])[1] || '';
        desc = raw
          .replace(/&lt;/g, '<').replace(/&gt;/g, '>')
          .replace(/&amp;/g, '&').replace(/&quot;/g, '"')
          .replace(/&#39;/g, "'");
      }

      const tm = rawTitle.match(/^Tick:\s*(.*?)\s*\(([^)]+)\)\s*$/);
      const name = tm ? tm[1].trim() : rawTitle.replace(/^Tick:\s*/, '').trim();
      const grade = tm ? tm[2].trim() : '';

      const decodeEnt = (s: string) => s
        .replace(/&hellip;/g, '…').replace(/&amp;/g, '&')
        .replace(/&lt;/g, '<').replace(/&gt;/g, '>').trim();
      const areaMatches = [...desc.matchAll(/href="[^"]*\/area\/[^"]*">([^<]+)<\/a>/g)];
      // Last 2 area levels give context without overflowing (e.g. "Whiskey Peak · N Face")
      const area = areaMatches.length >= 2
        ? areaMatches.slice(-2).map(m => decodeEnt(m[1])).join(' · ')
        : areaMatches.length === 1 ? decodeEnt(areaMatches[0][1]) : '';

      let date = '';
      if (pubDate) {
        try {
          date = new Date(pubDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
        } catch (_) {}
      }

      if (name) ticks.push({ name, grade, area, date, url: link });
    }
  }
} catch (e: unknown) {
  console.warn('[mp-ticks] fetch failed:', e instanceof Error ? e.message : String(e));
}

const preview = ticks.slice(0, 5);
const tickJSON = JSON.stringify(ticks).replace(/<\/script>/gi, '<\\/script>');
