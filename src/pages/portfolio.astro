      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .stack-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 26px;
      padding: 0 12px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      font-weight: var(--fw-medium);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      border-radius: var(--r-sm);
      border: 1px solid rgba(92, 107, 62, 0.22);
      background: rgba(244, 245, 236, 0.7);
      color: #4C5933;
      white-space: nowrap;
    }
    .featured-footer {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: auto;
      padding-top: 24px;
      border-top: 1px solid rgba(92, 107, 62, 0.15);
    }
    .featured-footer .pill.active {
      color: #5A7A3E;
      border-color: #CFDDB4;
      background: #E5EDD6;
    }
    .featured-footer .pill.active .dot { background: #5A7A3E; }
    .featured-status {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #6E7E4D;
    }
    .featured-screenshot {
      position: relative;
      overflow: hidden;
      background: #F4F5EC;
      border-left: 1px solid rgba(92, 107, 62, 0.18);
    }
    .featured-screenshot img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: auto;
      display: block;
    }

    @media (max-width: 900px) {
      .featured-card {
        grid-template-columns: 1fr;
      }
      .featured-screenshot {
        height: 240px;
        border-left: none;
        border-top: 1px solid rgba(92, 107, 62, 0.18);
        order: -1;
      }
      .featured-screenshot img {
        object-position: top center;
      }
      .featured-content {
        padding: 28px 24px;
      }
    }

    /* ── Forex Algo Trader featured project ──────────────────────── */
    .forex-wrap { margin-top: 40px; }
