  <script is:inline>
  (function () {
    function boot() {
      var el = document.getElementById('forex-chart');
      if (!el) return;
      var s = document.createElement('script');
      s.src = 'https://cdn.jsdelivr.net/npm/lightweight-charts@4.2.0/dist/lightweight-charts.standalone.production.js';
      s.onload = function () { init(el); };
      document.head.appendChild(s);
    }

    function lcg(seed) {
      var s = seed >>> 0;
      return function () {
        s = (Math.imul(s, 1664525) + 1013904223) >>> 0;
        return s / 4294967296;
      };
    }

    function init(el) {
      var chart = LightweightCharts.createChart(el, {
        width: el.clientWidth || 500,
        height: el.clientHeight || 440,
        layout: { background: { type: 'solid', color: '#0B1426' }, textColor: '#475569' },
        grid: {
          vertLines: { color: 'rgba(255,255,255,0.04)' },
          horzLines: { color: 'rgba(255,255,255,0.04)' },
        },
        crosshair: {
          vertLine: { color: 'rgba(20,184,166,0.6)', labelBackgroundColor: '#0D9488' },
          horzLine: { color: 'rgba(20,184,166,0.6)', labelBackgroundColor: '#0D9488' },
        },
        rightPriceScale: { borderColor: 'rgba(255,255,255,0.06)' },
        timeScale: { borderColor: 'rgba(255,255,255,0.06)', timeVisible: true, secondsVisible: false },
        watermark: {
          visible: true,
          fontSize: 11,
          horzAlign: 'left',
          vertAlign: 'top',
          color: 'rgba(255,255,255,0.10)',
          text: 'USD/EUR · Daily · 20-MA',
          fontFamily: 'monospace',
        },
        handleScroll: false,
        handleScale: false,
      });

      var series = chart.addCandlestickSeries({
        upColor: '#2DD4BF',
        downColor: '#F87171',
        borderVisible: false,
        wickUpColor: '#2DD4BF',
        wickDownColor: '#F87171',
      });
      var maLine = chart.addLineSeries({
        color: '#FBBF24',
        lineWidth: 1,
        priceLineVisible: false,
        lastValueVisible: false,
        crosshairMarkerVisible: false,
      });

      var rand = lcg(2741);
      var PERIOD = 20;
      var ohlc = [], closes = [], maData = [], markers = [];
      var close = 0.9215;
      var DAY = 86400;
      var calStart = Math.floor(Date.now() / 1000) - 128 * DAY;
      var count = 0;

      for (var d = 0; count < 90; d++) {
        var ts = calStart + d * DAY;
        var dow = new Date(ts * 1000).getUTCDay();
        if (dow === 0 || dow === 6) continue;
        count++;

        var t = count / 90;
        var drift = 0.00020 * Math.sin(t * Math.PI * 2.8 + 0.5) - 0.00008;
        var noise = (rand() - 0.5) * 0.0042;
        var open = close;
        close = Math.max(0.888, Math.min(0.958, open + drift + noise));
        var body = Math.abs(close - open);
        var hi = Math.max(open, close) + rand() * (body * 0.6 + 0.0009);
        var lo = Math.min(open, close) - rand() * (body * 0.6 + 0.0009);
        var snap = ts - (ts % DAY);

        ohlc.push({
          time: snap,
          open: +open.toFixed(4),
          high: +hi.toFixed(4),
          low: +lo.toFixed(4),
          close: +close.toFixed(4),
        });
        closes.push(close);

        var n = closes.length;
        if (n >= PERIOD) {
          var sum = 0;
          for (var i = n - PERIOD; i < n; i++) sum += closes[i];
          var ma = sum / PERIOD;
          maData.push({ time: snap, value: +ma.toFixed(4) });

          if (n > PERIOD) {
            var prevSum = 0;
            for (var j = n - PERIOD - 1; j < n - 1; j++) prevSum += closes[j];
            var prevMa = prevSum / PERIOD;
            var prevClose = closes[n - 2];
            if (prevClose < prevMa && close > ma) {
              markers.push({ time: snap, position: 'belowBar', color: '#2DD4BF', shape: 'arrowUp', size: 1 });
            } else if (prevClose > prevMa && close < ma) {
              markers.push({ time: snap, position: 'aboveBar', color: '#F87171', shape: 'arrowDown', size: 1 });
            }
          }
        }
      }

      series.setData(ohlc);
      maLine.setData(maData);
      series.setMarkers(markers);
      chart.timeScale().fitContent();

      new ResizeObserver(function () {
        chart.applyOptions({ width: el.clientWidth, height: el.clientHeight });
      }).observe(el);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', boot);
    } else {
      boot();
    }
  })();
  </script>
</InnerLayout>
