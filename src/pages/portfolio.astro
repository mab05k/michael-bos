<InnerLayout
  title="Portfolio"
  activePage="portfolio"
  description="Selected projects by Michael A. Bos — including Daybook, a field service management platform for small businesses, and an autonomous forex algorithmic trading system."
>
  <style is:global>
    .port-intro {
      max-width: 1280px;
      margin: 32px auto 0;
      padding: 0 24px;
    }
    .port-intro .eyebrow { margin-bottom: 12px; }
    .port-intro h1 {
      font-family: var(--font-sans);
      font-size: 56px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.025em;
      line-height: 1;
      color: var(--ink-900);
      margin: 0 0 18px;
    }
    .port-intro .dek {
      max-width: 68ch;
      color: var(--ink-700);
      font-size: var(--fs-16);
      line-height: 1.55;
      text-wrap: pretty;
      margin: 0;
    }

    .port-grid {
      max-width: 1280px;
      margin: 64px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .port-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .port-card-body {
      padding: 28px 28px 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .port-card .idn {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--rust);
    }
    .port-card .title {
      font-family: var(--font-display);
      font-weight: var(--fw-medium);
      font-size: 20px;
      letter-spacing: -0.015em;
      color: var(--ink-900);
    }
    .port-card .blurb {
      font-size: var(--fs-14);
      line-height: 1.55;
      color: var(--ink-700);
      text-wrap: pretty;
      flex: 1;
    }
    .port-card-footer {
      padding: 14px 28px;
      border-top: 1px solid var(--card-border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .port-card-footer .status {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
    }
    .port-card-footer .status.wip { color: var(--rust); }
    .port-card-footer .status.planned { color: var(--ink-500); }

    /* ── Daybook featured project ────────────────────────────── */
    .featured-wrap {
      max-width: 1280px;
      margin: 56px auto 0;
      padding: 0 24px;
    }
    .featured-label {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #5C6B3E;
      margin-bottom: 16px;
    }
    .featured-card {
      background: var(--card-bg);
      border: 1px solid rgba(92, 107, 62, 0.25);
      border-top: 3px solid #5C6B3E;
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 440px;
    }
    .featured-content {
      padding: 40px 44px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .featured-identity {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 6px;
    }
    .featured-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      flex-shrink: 0;
    }
    .featured-appname {
      font-family: var(--font-display);
      font-size: var(--fs-24);
      font-weight: var(--fw-semibold);
      letter-spacing: -0.02em;
      color: var(--canyon-ink);
      line-height: 1;
    }
    .featured-tagline {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #6E7E4D;
      margin-bottom: 20px;
    }
