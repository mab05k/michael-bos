  <header class="port-intro">
    <div class="eyebrow">Portfolio</div>
    <h1>Selected work.</h1>
    <p class="dek">
      A few things I've worked on to build my skills and challenge myself.
    </p>
  </header>

  <section class="featured-wrap" aria-label="Featured project">
    <div class="featured-label">Side hustle</div>
    <div class="featured-card">
      <div class="featured-content">
        <div class="featured-identity">
          <img src="/daybook-icon.svg" alt="Daybook icon" class="featured-icon" />
          <span class="featured-appname">Daybook</span>
        </div>
        <div class="featured-tagline">Field service management · Side project · In progress</div>
        <p class="featured-desc">
          An operations platform for small service businesses — plumbers, HVAC
          techs, landscapers — that typically run their schedules out of
          whiteboards and text messages. Daybook combines job scheduling, client
          management, invoicing, and team dispatch in one tool that scales from a
          one-person shop to a team of twenty.
        </p>
        <div class="featured-stack">
          <span class="stack-chip">Keycloak SSO</span>
          <span class="stack-chip">PHP / Symfony</span>
          <span class="stack-chip">API Platform</span>
          <span class="stack-chip">Go CLI</span>
          <span class="stack-chip">React SPA</span>
          <span class="stack-chip">React Native</span>
          <span class="stack-chip">Mercure</span>
          <span class="stack-chip">RabbitMQ</span>
          <span class="stack-chip">Turborepo</span>
        </div>
        <div class="featured-footer">
          <span class="pill active"><span class="dot"></span>Active</span>
          <span class="featured-status">In progress</span>
        </div>
      </div>
      <div class="featured-screenshot">
        <img src="/daybook-screenshot.png" alt="Daybook — day view showing scheduled visits, route preview, and earnings summary" />
      </div>
    </div>
  </section>

  <section class="featured-wrap forex-wrap" aria-label="Forex Algo Trader project">
    <div class="forex-label">Algorithmic trading · Archived</div>
    <div class="forex-card">
      <div class="forex-content">
        <div class="forex-identity">
          <span class="forex-appname">Forex Algo Trader</span>
        </div>
        <p class="forex-tagline">Autonomous trend-following · Live forex via Oanda API</p>
        <p class="forex-desc">
          Autonomous trend-following system for live forex trading via the Oanda API.
          Evaluates Heiken Ashi candles, 20-period moving averages, and Renko charts for market entry.
          Implements Zone Recovery — a counter-trend hedging strategy that layers opposing orders
          to recover from losing positions without closing at a loss.
        </p>
        <div class="forex-stack">
          <span class="forex-chip">PHP / Symfony</span>
          <span class="forex-chip">Oanda API</span>
          <span class="forex-chip">Heiken Ashi</span>
          <span class="forex-chip">Zone Recovery</span>
          <span class="forex-chip">Renko Charts</span>
          <span class="forex-chip">20-Period MA</span>
        </div>
        <div class="forex-footer">
          <span class="pill"><span class="dot"></span>Archived</span>
          <span class="forex-status">No longer maintained</span>
        </div>
      </div>
      <div class="forex-chart-panel">
        <svg
          class="forex-svg"
          viewBox={`0 0 ${CW} ${CH}`}
          preserveAspectRatio="none"
          role="img"
          aria-label="Simulated USD/EUR daily candlestick chart with a 20-period moving average and trend-crossing entry markers"
        >
          {gridY.map(gy => (
            <line x1={PX} x2={CW - PX} y1={gy} y2={gy} stroke="rgba(255,255,255,0.05)" vector-effect="non-scaling-stroke" />
          ))}
          {gridX.map(gx => (
            <line x1={gx} x2={gx} y1={PT} y2={CH - PB} stroke="rgba(255,255,255,0.04)" vector-effect="non-scaling-stroke" />
          ))}
          {candles.map(c => (
            <>
              <line
                x1={c.cx} x2={c.cx} y1={c.yHi} y2={c.yLo}
                stroke={c.up ? '#2DD4BF' : '#F87171'}
                stroke-width="1"
                vector-effect="non-scaling-stroke"
              />
              <rect x={c.x} y={c.yBody} width={bodyW} height={c.hBody} fill={c.up ? '#2DD4BF' : '#F87171'} />
            </>
          ))}
          <polyline points={maPoints} fill="none" stroke="#FBBF24" stroke-width="1.2" vector-effect="non-scaling-stroke" />
          {markers.map(m => (
            <polygon points={m.points} fill={m.color} />
          ))}
        </svg>
        <div class="forex-watermark">USD/EUR · Daily · 20-MA</div>
      </div>
    </div>
  </section>

