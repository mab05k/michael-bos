---
import InnerLayout from '../layouts/InnerLayout.astro';
---
<InnerLayout
  title="Portfolio"
  activePage="portfolio"
  description="Selected projects by Michael A. Bos — including Daybook, a field service management platform for small businesses, and an autonomous forex algorithmic trading system."
>
  <style is:global>
    .port-intro {
      max-width: 1280px;
      margin: 32px auto 0;
      padding: 0 24px;
    }
    .port-intro .eyebrow { margin-bottom: 12px; }
    .port-intro h1 {
      font-family: var(--font-sans);
      font-size: 56px;
      font-weight: var(--fw-medium);
      letter-spacing: -0.025em;
      line-height: 1;
      color: var(--ink-900);
      margin: 0 0 18px;
    }
    .port-intro .dek {
      max-width: 68ch;
      color: var(--ink-700);
      font-size: var(--fs-16);
      line-height: 1.55;
      text-wrap: pretty;
      margin: 0;
    }

    .port-grid {
      max-width: 1280px;
      margin: 64px auto 0;
      padding: 0 24px;
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .port-card {
      background: var(--card-bg);
      border: 1px solid var(--card-border);
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }
    .port-card-body {
      padding: 28px 28px 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .port-card .idn {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: var(--rust);
    }
    .port-card .title {
      font-family: var(--font-display);
      font-weight: var(--fw-medium);
      font-size: 20px;
      letter-spacing: -0.015em;
      color: var(--ink-900);
    }
    .port-card .blurb {
      font-size: var(--fs-14);
      line-height: 1.55;
      color: var(--ink-700);
      text-wrap: pretty;
      flex: 1;
    }
    .port-card-footer {
      padding: 14px 28px;
      border-top: 1px solid var(--card-border);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .port-card-footer .status {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
    }
    .port-card-footer .status.wip { color: var(--rust); }
    .port-card-footer .status.planned { color: var(--ink-500); }

    /* ── Daybook featured project ────────────────────────────── */
    .featured-wrap {
      max-width: 1280px;
      margin: 56px auto 0;
      padding: 0 24px;
    }
    .featured-label {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #5C6B3E;
      margin-bottom: 16px;
    }
    .featured-card {
      background: var(--card-bg);
      border: 1px solid rgba(92, 107, 62, 0.25);
      border-top: 3px solid #5C6B3E;
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 440px;
    }
    .featured-content {
      padding: 40px 44px;
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .featured-identity {
      display: flex;
      align-items: center;
      gap: 14px;
      margin-bottom: 6px;
    }
    .featured-icon {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      flex-shrink: 0;
    }
    .featured-appname {
      font-family: var(--font-display);
      font-size: var(--fs-24);
      font-weight: var(--fw-semibold);
      letter-spacing: -0.02em;
      color: var(--canyon-ink);
      line-height: 1;
    }
    .featured-tagline {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #6E7E4D;
      margin-bottom: 20px;
    }
    .featured-desc {
      font-size: var(--fs-16);
      line-height: 1.6;
      color: var(--canyon-shadow);
      text-wrap: pretty;
      margin-bottom: 28px;
    }
    .featured-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .stack-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      height: 26px;
      padding: 0 12px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      font-weight: var(--fw-medium);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      border-radius: var(--r-sm);
      border: 1px solid rgba(92, 107, 62, 0.22);
      background: rgba(244, 245, 236, 0.7);
      color: #4C5933;
      white-space: nowrap;
    }
    .featured-footer {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: auto;
      padding-top: 24px;
      border-top: 1px solid rgba(92, 107, 62, 0.15);
    }
    .featured-footer .pill.active {
      color: #5A7A3E;
      border-color: #CFDDB4;
      background: #E5EDD6;
    }
    .featured-footer .pill.active .dot { background: #5A7A3E; }
    .featured-status {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #6E7E4D;
    }
    .featured-screenshot {
      position: relative;
      overflow: hidden;
      background: #F4F5EC;
      border-left: 1px solid rgba(92, 107, 62, 0.18);
    }
    .featured-screenshot img {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: auto;
      display: block;
    }

    @media (max-width: 900px) {
      .featured-card {
        grid-template-columns: 1fr;
      }
      .featured-screenshot {
        height: 240px;
        border-left: none;
        border-top: 1px solid rgba(92, 107, 62, 0.18);
        order: -1;
      }
      .featured-screenshot img {
        object-position: top center;
      }
      .featured-content {
        padding: 28px 24px;
      }
    }

    /* ── Forex Algo Trader featured project ──────────────────────── */
    .forex-wrap { margin-top: 40px; }
    .forex-label {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #0D9488;
      margin-bottom: 16px;
    }
    .forex-card {
      background: var(--card-bg);
      border: 1px solid rgba(20, 184, 166, 0.22);
      border-top: 3px solid #0D9488;
      border-radius: var(--r-lg);
      box-shadow: var(--shadow-sm);
      overflow: hidden;
      display: grid;
      grid-template-columns: 1fr 1fr;
      min-height: 440px;
    }
    .forex-content {
      padding: 40px 44px;
      display: flex;
      flex-direction: column;
    }
    .forex-identity { margin-bottom: 6px; }
    .forex-appname {
      font-family: var(--font-display);
      font-size: var(--fs-24);
      font-weight: var(--fw-semibold);
      letter-spacing: -0.02em;
      color: var(--ink-900);
      line-height: 1;
    }
    .forex-tagline {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #0D9488;
      margin: 0 0 20px;
    }
    .forex-desc {
      font-size: var(--fs-16);
      line-height: 1.6;
      color: var(--ink-700);
      text-wrap: pretty;
      margin: 0 0 28px;
    }
    .forex-stack {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: 28px;
    }
    .forex-chip {
      display: inline-flex;
      align-items: center;
      height: 26px;
      padding: 0 12px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      font-weight: var(--fw-medium);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      border-radius: var(--r-sm);
      border: 1px solid rgba(20, 184, 166, 0.25);
      background: rgba(204, 251, 241, 0.5);
      color: #0F766E;
      white-space: nowrap;
    }
    .forex-footer {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: auto;
      padding-top: 24px;
      border-top: 1px solid rgba(20, 184, 166, 0.15);
    }
    .forex-status {
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: var(--tr-caps);
      text-transform: uppercase;
      color: #0D9488;
    }
    .forex-chart-panel {
      position: relative;
      overflow: hidden;
      background: #0B1426;
      border-left: 1px solid rgba(20, 184, 166, 0.18);
    }
    #forex-chart { position: absolute; inset: 0; }

    @media (max-width: 900px) {
      .forex-card { grid-template-columns: 1fr; }
      .forex-chart-panel {
        height: 240px;
        border-left: none;
        border-top: 1px solid rgba(20, 184, 166, 0.18);
        order: -1;
      }
      .forex-content { padding: 28px 24px; }
    }

    @media (max-width: 900px) {
      .port-intro h1 { font-size: 40px; }
      .port-grid { grid-template-columns: 1fr; }
    }
  </style>

  <header class="port-intro">
    <div class="eyebrow">Portfolio</div>
    <h1>Selected work.</h1>
    <p class="dek">
      A few things I've worked on to build my skills and challenge myself.
    </p>
  </header>

  <section class="featured-wrap" aria-label="Featured project">
    <div class="featured-label">Side hustle</div>
    <div class="featured-card">
      <div class="featured-content">
        <div class="featured-identity">
          <img src="/daybook-icon.svg" alt="Daybook icon" class="featured-icon" />
          <span class="featured-appname">Daybook</span>
        </div>
        <div class="featured-tagline">Field service management · Side project · In progress</div>
        <p class="featured-desc">
          A structured operations platform for the smallest service businesses — plumbers,
          HVAC techs, landscapers — who run complex schedules out of whiteboards and text
          messages. Daybook replaces the patchwork: job scheduling, client management,
          invoicing, and team dispatch in one purpose-built tool that grows from a one-person
          shop to a team of twenty without forcing a platform switch.
        </p>
        <div class="featured-stack">
          <span class="stack-chip">Keycloak SSO</span>
          <span class="stack-chip">PHP / Symfony</span>
          <span class="stack-chip">API Platform</span>
          <span class="stack-chip">Go CLI</span>
          <span class="stack-chip">React SPA</span>
          <span class="stack-chip">React Native</span>
          <span class="stack-chip">Mercure</span>
          <span class="stack-chip">RabbitMQ</span>
          <span class="stack-chip">Turborepo</span>
        </div>
        <div class="featured-footer">
          <span class="pill active"><span class="dot"></span>Active</span>
          <span class="featured-status">In progress</span>
        </div>
      </div>
      <div class="featured-screenshot">
        <img src="/daybook-screenshot.png" alt="Daybook — day view showing scheduled visits, route preview, and earnings summary" />
      </div>
    </div>
  </section>

  <section class="featured-wrap forex-wrap" aria-label="Forex Algo Trader project">
    <div class="forex-label">Algorithmic trading · Archived</div>
    <div class="forex-card">
      <div class="forex-content">
        <div class="forex-identity">
          <span class="forex-appname">Forex Algo Trader</span>
        </div>
        <p class="forex-tagline">Autonomous trend-following · Live forex via Oanda API</p>
        <p class="forex-desc">
          Autonomous trend-following system for live forex trading via the Oanda API.
          Evaluates Heiken Ashi candles, 20-period moving averages, and Renko charts for market entry.
          Implements Zone Recovery — a counter-trend hedging strategy that layers opposing orders
          to recover from losing positions without closing at a loss.
        </p>
        <div class="forex-stack">
          <span class="forex-chip">PHP / Symfony</span>
          <span class="forex-chip">Oanda API</span>
          <span class="forex-chip">Heiken Ashi</span>
          <span class="forex-chip">Zone Recovery</span>
          <span class="forex-chip">Renko Charts</span>
          <span class="forex-chip">20-Period MA</span>
        </div>
        <div class="forex-footer">
          <span class="pill"><span class="dot"></span>Archived</span>
          <span class="forex-status">No longer maintained</span>
        </div>
      </div>
      <div class="forex-chart-panel">
        <div id="forex-chart"></div>
      </div>
    </div>
  </section>

