---
import InnerLayout from '../layouts/InnerLayout.astro';

// ── Forex chart — rendered to static SVG at build time ─────────
// The previous version drew this at runtime with lightweight-charts
// from a CDN, which silently failed under client-side navigation.
// Same seeded data, now baked into the HTML so it always renders.
function lcg(seed: number) {
  let s = seed >>> 0;
  return () => {
    s = (Math.imul(s, 1664525) + 1013904223) >>> 0;
    return s / 4294967296;
  };
}

const rand = lcg(2741);
const PERIOD = 20;
const BARS = 90;

interface Bar { o: number; h: number; l: number; c: number; }
const bars: Bar[] = [];
const closes: number[] = [];
let close = 0.9215;

for (let k = 0; k < BARS; k++) {
  const t = (k + 1) / BARS;
  const drift = 0.0002 * Math.sin(t * Math.PI * 2.8 + 0.5) - 0.00008;
  const noise = (rand() - 0.5) * 0.0042;
  const o = close;
  close = Math.max(0.888, Math.min(0.958, o + drift + noise));
  const body = Math.abs(close - o);
  const h = Math.max(o, close) + rand() * (body * 0.6 + 0.0009);
  const l = Math.min(o, close) - rand() * (body * 0.6 + 0.0009);
  bars.push({ o, h, l, c: close });
  closes.push(close);
}

const ma: (number | null)[] = closes.map((_, n) =>
  n + 1 >= PERIOD
    ? closes.slice(n + 1 - PERIOD, n + 1).reduce((a, b) => a + b, 0) / PERIOD
    : null
);

const CW = 600, CH = 440, PX = 10, PT = 30, PB = 20;
const hiAll = Math.max(...bars.map(b => b.h));
const loAll = Math.min(...bars.map(b => b.l));
const py = (p: number) => +(PT + ((hiAll - p) / (hiAll - loAll)) * (CH - PT - PB)).toFixed(1);
const step = (CW - 2 * PX) / BARS;
const bodyW = +(step * 0.62).toFixed(1);

const candles = bars.map((b, k) => {
  const cx = +(PX + step * (k + 0.5)).toFixed(1);
  return {
    cx,
    x: +(cx - bodyW / 2).toFixed(1),
    yBody: py(Math.max(b.o, b.c)),
    hBody: Math.max(1.5, +Math.abs(py(b.o) - py(b.c)).toFixed(1)),
    yHi: py(b.h),
    yLo: py(b.l),
    up: b.c >= b.o,
  };
});

const maPoints = ma
  .map((v, k) => (v == null ? null : `${(PX + step * (k + 0.5)).toFixed(1)},${py(v)}`))
  .filter(Boolean)
  .join(' ');

// Trend-crossing markers, same rule the live system used
const markers: { points: string; color: string }[] = [];
for (let k = PERIOD; k < BARS; k++) {
  const prevMa = ma[k - 1], curMa = ma[k];
  if (prevMa == null || curMa == null) continue;
  const c = candles[k];
  if (closes[k - 1] < prevMa && closes[k] > curMa) {
    const yy = c.yLo + 5;
    markers.push({ points: `${c.cx},${yy} ${+(c.cx - 4).toFixed(1)},${+(yy + 8).toFixed(1)} ${+(c.cx + 4).toFixed(1)},${+(yy + 8).toFixed(1)}`, color: '#2DD4BF' });
  } else if (closes[k - 1] > prevMa && closes[k] < curMa) {
    const yy = c.yHi - 5;
    markers.push({ points: `${c.cx},${yy} ${+(c.cx - 4).toFixed(1)},${+(yy - 8).toFixed(1)} ${+(c.cx + 4).toFixed(1)},${+(yy - 8).toFixed(1)}`, color: '#F87171' });
  }
}

const gridY = [0, 1, 2, 3, 4].map(i => +(PT + (i * (CH - PT - PB)) / 4).toFixed(1));
const gridX = [15, 30, 45, 60, 75].map(i => +(PX + step * i).toFixed(1));
