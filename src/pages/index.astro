---
import InnerLayout from '../layouts/InnerLayout.astro';
---
<InnerLayout activePage="home">
  <style is:global>

    /* ── Hero ─────────────────────────────────────────────── */
    .hero {
      display: grid;
      grid-template-columns: minmax(320px, 680px) minmax(280px, 500px);
      justify-content: center;
      min-height: calc(100svh - 65px);
      background: var(--bg-bone);
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background: radial-gradient(90% 80% at 0% 55%, rgba(184,74,38,0.07), transparent 62%);
    }
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 56px 80px clamp(24px, 7vw, 80px);
      position: relative;
      z-index: 1;
    }
    .hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 22px;
    }
    .hero-kicker .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--status-pass);
      box-shadow: 0 0 0 3px rgba(63,138,79,0.25);
    }
    .hero-h1 {
      font-family: var(--font-display);
      font-weight: var(--fw-semibold);
      font-size: clamp(40px, 5.2vw, 62px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      color: var(--canyon-ink);
      margin: 0 0 20px;
      max-width: 16ch;
      text-wrap: balance;
    }
    .hero-lede {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      line-height: var(--lh-relaxed);
      color: var(--canyon-shadow);
      margin: 0 0 32px;
      max-width: 46ch;
    }
    .hero-actions {
      display: flex;
      gap: 12px;
      flex-wrap: wrap;
    }
    .btn {
      font-family: var(--font-display);
      font-weight: var(--fw-medium);
      font-size: 15px;
      padding: 12px 22px;
      border-radius: var(--r-sm);
      border: none;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      text-decoration: none;
      transition:
        background var(--dur-fast) var(--ease-out),
        color var(--dur-fast) var(--ease-out),
        box-shadow var(--dur-fast) var(--ease-out),
        transform var(--dur-fast) var(--ease-out);
    }
    .btn:active { transform: translateY(1px); }
    .btn svg { width: 16px; height: 16px; flex-shrink: 0; }
    .btn-primary {
      background: var(--rust);
      color: #fff;
    }
    .btn-primary:hover { background: var(--rust-deep); color: #fff; text-decoration: none; }
    .btn-secondary-dark {
      background: transparent;
      color: var(--canyon-ink);
      box-shadow: inset 0 0 0 1.5px var(--canyon-shadow);
    }
    .btn-secondary-dark:hover {
      background: var(--canyon-ink);
      color: var(--bg-bone);
      text-decoration: none;
    }

    /* ── Hero right (photo) ────────────────────────────────── */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 36% 5%;
      display: block;
    }
    .hero-img-tag {
      position: absolute;
      left: 16px;
      bottom: 20px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: 0.06em;
      color: rgba(240,228,210,0.92);
      padding: 5px 12px;
      background: rgba(14,17,21,0.52);
      border-radius: var(--r-pill);
      backdrop-filter: blur(4px);
    }

    /* ── Responsive ─────────────────────────────────────────── */
    @media (max-width: 860px) {
      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .hero-left {
        padding: 60px 24px 48px;
      }
      .hero-right {
        height: 360px;
      }
      .hero-right img {
        object-position: 36% 20%;
      }
    }
  </style>

  <main>
    <section class="hero">
      <div class="hero-left">
        <div class="hero-kicker">
          <span class="dot"></span>
          Engineering Manager · Las Vegas, NV
        </div>
        <h1 class="hero-h1">Ship boring code.<br>Build calm teams.</h1>
        <p class="hero-lede">
          I lead engineering teams that ship — fast, calm, and on a clean trunk.
          Twelve years of code, six years on the rope, six in the Navy.
        </p>
        <div class="hero-actions">
          <a class="btn btn-primary" href="mailto:mab05k@gmail.com">
            Get in touch
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
            </svg>
          </a>
          <a class="btn btn-secondary-dark" href="/biography">Read the story</a>
        </div>
      </div>
      <div class="hero-right">
        <img
          src="/michael-bos-action.jpg"
          alt="Michael Bos climbing red sandstone in Red Rock Canyon, Nevada"
        >
        <div class="hero-img-tag">36°08′N · 115°27′W · Red Rock, NV</div>
      </div>
    </section>
  </main>

</InnerLayout>
