---
import InnerLayout from '../layouts/InnerLayout.astro';
import { User, FileText, Briefcase } from '@lucide/astro';
---
<InnerLayout activePage="home">
  <style is:global>

    /* ── Hero ─────────────────────────────────────────────── */
    .hero {
      display: grid;
      grid-template-columns: minmax(320px, 680px) minmax(280px, 500px);
      justify-content: center;
      min-height: calc(100svh - 65px);
      background: var(--bg-bone);
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 0;
      background: radial-gradient(90% 80% at 0% 55%, rgba(184,74,38,0.07), transparent 62%);
    }
    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 56px 80px clamp(24px, 7vw, 80px);
      position: relative;
      z-index: 1;
    }
    .hero-kicker {
      display: inline-flex;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: var(--fs-12);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rust);
      margin-bottom: 22px;
    }
    @keyframes pulse-ring {
      0%   { box-shadow: 0 0 0 0   rgba(63,138,79,0.55); }
      70%  { box-shadow: 0 0 0 6px rgba(63,138,79,0);    }
      100% { box-shadow: 0 0 0 0   rgba(63,138,79,0);    }
    }
    .hero-kicker .dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--status-pass);
      box-shadow: 0 0 0 0 rgba(63,138,79,0.55);
      animation: pulse-ring 2s ease-out infinite;
    }
    .hero-h1 {
      font-family: var(--font-display);
      font-weight: var(--fw-semibold);
      font-size: clamp(40px, 5.2vw, 62px);
      line-height: 1.02;
      letter-spacing: -0.025em;
      color: var(--canyon-ink);
      margin: 0 0 20px;
      max-width: 16ch;
      text-wrap: balance;
    }
    .hero-lede {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      line-height: var(--lh-relaxed);
      color: var(--canyon-shadow);
      margin: 0 0 32px;
      max-width: 46ch;
    }
    .hero-actions {
      display: flex;
      gap: 12px;
    }
    .btn {
      font-family: var(--font-display);
      font-weight: var(--fw-medium);
      font-size: 14px;
      padding: 7px 18px;
      border-radius: var(--r-pill);
      border: none;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      text-decoration: none;
      flex: 1;
      transition:
        background var(--dur-base) var(--ease-out),
        color var(--dur-base) var(--ease-out),
        transform var(--dur-fast) var(--ease-out);
    }
    .btn:active { transform: translateY(1px); }
    .btn svg { width: 16px; height: 16px; flex-shrink: 0; }
    .btn-primary {
      background: color-mix(in oklab, var(--rust) 13%, transparent);
      color: var(--rust);
      font-weight: var(--fw-semibold);
    }
    .btn-primary:hover { background: color-mix(in oklab, var(--rust) 22%, transparent); color: var(--rust-deep); text-decoration: none; }
    .btn-secondary-dark {
      background: transparent;
      color: var(--canyon-fade);
    }
    .btn-secondary-dark:hover {
      background: color-mix(in oklab, var(--canyon-ink) 8%, transparent);
      color: var(--canyon-ink);
      text-decoration: none;
    }

    /* ── Hero right (photo) ────────────────────────────────── */
    .hero-right {
      position: relative;
      overflow: hidden;
    }
    .hero-right img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: 36% 5%;
      display: block;
    }
    .hero-img-tag {
      position: absolute;
      left: 16px;
      bottom: 20px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: 0.06em;
      color: rgba(240,228,210,0.92);
      padding: 5px 12px;
      background: rgba(14,17,21,0.52);
      border-radius: var(--r-pill);
      backdrop-filter: blur(4px);
    }
    .hero-img-tag-top-right {
      position: absolute;
      right: 16px;
      top: 40px;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      font-family: var(--font-mono);
      font-size: var(--fs-11);
      letter-spacing: 0.06em;
      color: rgba(240,228,210,0.92);
      padding: 5px 12px;
      background: rgba(14,17,21,0.52);
      border-radius: var(--r-pill);
      backdrop-filter: blur(4px);
    }

    /* ── Responsive ─────────────────────────────────────────── */
    @media (max-width: 860px) {
      .hero {
        grid-template-columns: 1fr;
        min-height: auto;
      }
      .hero-left {
        padding: 60px 24px 48px;
      }
      .hero-right {
        height: 360px;
      }
      .hero-right img {
        object-position: 36% 20%;
      }
    }
  </style>

  <main>
    <section class="hero">
      <div class="hero-left">
        <div class="hero-kicker">
          <span class="dot"></span>
          Senior Engineering Manager · Las Vegas, NV
        </div>
        <h1 class="hero-h1">Engineering leader. Always learning.</h1>
        <p class="hero-lede">
          Twelve years building software and leading the teams who ship it.
          Wherever I've worked, I've built the strong foundations everyone wishes existed
          from day one: testable software, local development environments, CI/CD, deployment pipelines,
          release automation. I adapt fast and earn trust quickly — from serving as a J2 in the U.S. Navy to
          a software career, an Executive MBA, and now engineering leadership.
        </p>
        <div class="hero-actions">
          <a class="btn btn-secondary-dark" href="/biography"><User size={16} />Biography</a>
          <a class="btn btn-primary" href="/resume"><FileText size={16} />Resume</a>
          <a class="btn btn-secondary-dark" href="/portfolio"><Briefcase size={16} />Portfolio</a>
        </div>
      </div>
      <div class="hero-right">
        <img
          src="/michael-bos-action.jpg"
          alt="Michael Bos climbing red sandstone in Red Rock Canyon, Nevada"
        >
        <div class="hero-img-tag">36°08′N · 115°27′W · Red Rock, NV</div>
        <div class="hero-img-tag-top-right">Black Velvet Canyon > Dream of Wild Turkeys · 5.10a</div>
      </div>
    </section>
  </main>

</InnerLayout>
