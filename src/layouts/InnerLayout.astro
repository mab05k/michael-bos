---
import '../styles/shared.css';
import SiteHeader from '../components/SiteHeader.astro';
import { ClientRouter } from 'astro:transitions';
const { title, description, activePage } = Astro.props;

const pageTitle = title ? `${title} — Michael Bos` : 'Michael Bos';
const pageDescription = description ?? 'Senior Engineering Manager with twelve years building software and leading teams. Based in Las Vegas, NV.';
const canonicalURL = new URL(Astro.url.pathname, 'https://michael-bos.com');
---
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{pageTitle}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <meta name="description" content={pageDescription}>
  <meta name="author" content="Michael A. Bos">
  <link rel="canonical" href={canonicalURL}>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" href="/favicon.ico">
  <!-- Open Graph -->
  <meta property="og:type" content="website">
  <meta property="og:url" content={canonicalURL}>
  <meta property="og:title" content={pageTitle}>
  <meta property="og:description" content={pageDescription}>
  <meta property="og:image" content="https://michael-bos.com/og-image.png">
  <ClientRouter />
</head>
<body>

  <SiteHeader activePage={activePage} />

  <slot />

  <footer class="site-footer" style="margin-top: 80px;">
    <div class="site-footer-inner">
      <div>© 2026 · Michael A. Bos · Las&nbsp;Vegas, NV</div>
      <div style="display:flex; gap:18px;">
        <a href="mailto:mab05k@gmail.com">mab05k@gmail.com</a>
        <a href="https://www.linkedin.com/in/michael-a-bos/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/mab05k" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
