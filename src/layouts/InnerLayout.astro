---
import '../styles/shared.css';
const { title, activePage } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{title ? `${title} — Michael Bos` : 'Michael Bos'}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" href="/favicon.ico">
</head>
<body>

  <header class="site-header">
    <div class="brand">
      <svg class="mark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4">
        <circle cx="12" cy="12" r="9"></circle>
        <circle cx="12" cy="12" r="3.5"></circle>
        <line x1="12" y1="1" x2="12" y2="6"></line>
        <line x1="12" y1="18" x2="12" y2="23"></line>
        <line x1="1" y1="12" x2="6" y2="12"></line>
        <line x1="18" y1="12" x2="23" y2="12"></line>
      </svg>
      <a href="/" class="wm">M.A. Bos</a>
    </div>
    <nav class="sitenav">
      <a href="/" class={activePage === 'home' ? 'current' : ''}><span class="idxn">01</span>Home</a>
      <a href="/biography" class={activePage === 'biography' ? 'current' : ''}><span class="idxn">02</span>Biography</a>
      <a href="/resume" class={activePage === 'resume' ? 'current' : ''}><span class="idxn">03</span>Resume</a>
    </nav>
  </header>

  <slot />

  <footer class="site-footer" style="margin-top: 96px;">
    <div class="site-footer-inner">
      <div>© 2026 · Michael A. Bos · Las&nbsp;Vegas, NV</div>
      <div style="display:flex; gap:18px;">
        <a href="mailto:mab05k@gmail.com">mab05k@gmail.com</a>
        <a href="https://www.linkedin.com/in/michael-a-bos/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/mab05k" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
