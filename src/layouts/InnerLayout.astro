---
import '../styles/shared.css';
const { title, activePage } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{title ? `${title} — Michael Bos` : 'Michael Bos'}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" href="/favicon.ico">
</head>
<body>

  <header class="site-header">
    <div class="site-header-inner">
      <a href="/" class="brand">
        <svg class="mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
          <rect width="32" height="32" rx="6" fill="#1F140C"/>
          <path d="M6 22 L11 12 L14 18 L17 13 L22 21 L26 14" stroke="#B84A26" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
          <circle cx="22" cy="9" r="1.6" fill="#D4892C"/>
        </svg>
        <span class="wm">michael <span class="slash">/</span> bos</span>
      </a>
      <nav class="sitenav">
        <a href="/" class={activePage === 'home' ? 'current' : ''}><span class="idxn">01</span>Home</a>
        <a href="/biography" class={activePage === 'biography' ? 'current' : ''}><span class="idxn">02</span>Biography</a>
        <a href="/resume" class={activePage === 'resume' ? 'current' : ''}><span class="idxn">03</span>Resume</a>
      </nav>
    </div>
  </header>

  <slot />

  <footer class="site-footer" style="margin-top: 80px;">
    <div class="site-footer-inner">
      <div>© 2026 · Michael A. Bos · Las&nbsp;Vegas, NV</div>
      <div style="display:flex; gap:18px;">
        <a href="mailto:mab05k@gmail.com">mab05k@gmail.com</a>
        <a href="https://www.linkedin.com/in/michael-a-bos/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/mab05k" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
