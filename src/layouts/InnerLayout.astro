---
import '../styles/shared.css';
import SiteHeader from '../components/SiteHeader.astro';
const { title, activePage } = Astro.props;
---
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{title ? `${title} — Michael Bos` : 'Michael Bos'}</title>
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" href="/favicon.ico">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@400;500;700&display=swap">
</head>
<body>

  <SiteHeader activePage={activePage} />

  <slot />

  <footer class="site-footer" style="margin-top: 80px;">
    <div class="site-footer-inner">
      <div>© 2026 · Michael A. Bos · Las&nbsp;Vegas, NV</div>
      <div style="display:flex; gap:18px;">
        <a href="mailto:mab05k@gmail.com">mab05k@gmail.com</a>
        <a href="https://www.linkedin.com/in/michael-a-bos/" target="_blank" rel="noopener">LinkedIn</a>
        <a href="https://github.com/mab05k" target="_blank" rel="noopener">GitHub</a>
      </div>
    </div>
  </footer>

</body>
</html>
