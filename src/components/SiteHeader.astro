---
const { activePage } = Astro.props;
---
<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="brand">
      <span class="mark-chip" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="4 17 10 11 4 5"/>
          <line x1="12" y1="19" x2="20" y2="19"/>
        </svg>
      </span>
      <span class="wm">michael <span class="slash">/</span> bos</span>
    </a>
    <nav class="topnav" aria-label="Primary">
      <a class={`topnav-link${activePage === 'home' ? ' is-active' : ''}`} href="/">Home</a>
      <a class={`topnav-link${activePage === 'biography' ? ' is-active' : ''}`} href="/biography">Bio</a>
      <a class={`topnav-link${activePage === 'resume' ? ' is-active' : ''}`} href="/resume">Resume</a>
      <a class={`topnav-link${activePage === 'portfolio' ? ' is-active' : ''}`} href="/portfolio">Portfolio</a>
    </nav>
    <div class="topbar-right-wrapper">
      <slot name="right">
        <span class="loc"><span class="pin"></span>Las Vegas, NV</span>
      </slot>
    </div>
  </div>
</header>
