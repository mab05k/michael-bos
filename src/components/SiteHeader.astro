---
const { activePage } = Astro.props;
---
<header class="site-header">
  <div class="site-header-inner">
    <a href="/" class="brand">
      <svg class="mark" width="28" height="28" viewBox="0 0 32 32" fill="none" aria-hidden="true">
        <rect width="32" height="32" rx="6" fill="#1F140C"/>
        <path d="M6 22 L11 12 L14 18 L17 13 L22 21 L26 14" stroke="#B84A26" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="22" cy="9" r="1.6" fill="#D4892C"/>
      </svg>
      <span class="wm">michael <span class="slash">/</span> bos</span>
    </a>
    <nav class="sitenav">
      <a href="/" class={activePage === 'home' ? 'current' : ''}>Home</a>
      <a href="/biography" class={activePage === 'biography' ? 'current' : ''}>Bio</a>
      <a href="/resume" class={activePage === 'resume' ? 'current' : ''}>Resume</a>
      <a href="/portfolio" class={activePage === 'portfolio' ? 'current' : ''}>Portfolio</a>
      <span class="nav-status"><span class="dot"></span>main · 12 deploys today</span>
    </nav>
  </div>
</header>
